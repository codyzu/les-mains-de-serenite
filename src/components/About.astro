---
import {Image, Picture} from 'astro:assets';
import type {AboutData} from '../data/site';
import Practitioner from '../assets/about-practitioner.png';
import LogoSquareDark from '../assets/logo-square-dark.png';
import SectionIntro from './SectionIntro.astro';

type Props = AboutData;

const {title, body, imageAlt} = Astro.props;
const paragraphs = body
  .split(/\n\s*\n/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean);
---

<section id="apropos" class="section-pad bg-surface-muted">
  <div class="container-page">
    <div class="mb-6 hidden justify-center lg:flex">
      <div class="flex items-center justify-center gap-5 text-ink/78">
        <Image
          src={LogoSquareDark}
          alt=""
          width={264}
          height={264}
          class="h-22 w-22 shrink-0 opacity-80"
          loading="lazy"
          decoding="async"
          fetchpriority="low"
        />
        <div>
          <p class="font-display text-4xl leading-none text-ink/78">
            Les Mains de Sérénité
          </p>
          <p class="mt-2 text-base leading-none text-ink/58">Massothérapeute</p>
        </div>
      </div>
    </div>

    <div class="grid items-center gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:gap-14">
      <div class="order-2 lg:order-1">
        <div
          class="mx-auto mb-4 flex max-w-sm flex-col items-center justify-center gap-3 text-center text-ink/78 sm:mb-5 sm:max-w-none sm:flex-row sm:gap-4 sm:text-left lg:hidden"
        >
          <Image
            src={LogoSquareDark}
            alt=""
            width={216}
            height={216}
            class="h-18 w-18 shrink-0 opacity-80"
            loading="lazy"
            decoding="async"
            fetchpriority="low"
          />
          <div>
            <p
              class="font-display text-3xl leading-none text-ink/78 sm:text-4xl"
            >
              Les Mains de Sérénité
            </p>
            <p class="mt-2 text-sm leading-none text-ink/58">Massothérapeute</p>
          </div>
        </div>
        <SectionIntro title={title} centered={false} />
        <div class="space-y-5">
          {paragraphs.map((paragraph) => <p class="body-lg">{paragraph}</p>)}
        </div>
      </div>

      <div class="order-1 lg:order-2">
        <div
          class="overflow-hidden rounded-[2rem] shadow-soft ring-1 ring-surface-soft"
        >
          <Picture
            src={Practitioner}
            formats={['avif', 'webp']}
            alt={imageAlt}
            class="h-[420px] w-full object-cover object-top"
            loading="lazy"
            decoding="async"
            fetchpriority="low"
          />
        </div>
      </div>
    </div>
  </div>
</section>
