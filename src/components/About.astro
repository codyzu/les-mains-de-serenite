---
import SectionIntro from './SectionIntro.astro';

interface Props {
  title: string;
  paragraphs: string[];
}

const {title, paragraphs} = Astro.props;
---

<section id="apropos" class="section-pad bg-surface-muted">
  <div class="container-page">
    <div
      class="grid items-center gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:gap-14"
    >
      <div class="order-2 lg:order-1">
        <SectionIntro title={title} centered={false} />
        <div class="space-y-5">
          {paragraphs.map((paragraph) => <p class="body-lg">{paragraph}</p>)}
        </div>
      </div>

      <div class="order-1 lg:order-2">
        <div
          class="overflow-hidden rounded-[2rem] shadow-soft ring-1 ring-surface-soft"
        >
          <img
            src="/images/about-practitioner.png"
            alt="Ambiance bien-être et massage"
            class="h-[420px] w-full object-cover object-[center_10%]"
          />
        </div>
      </div>
    </div>
  </div>
</section>
