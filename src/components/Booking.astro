---
import type {HomePageData} from '../data/site';
import IconImage from './IconImage.astro';

type Props = HomePageData['booking'] & {
  bookingUrl: string;
};

const {bookingUrl, title, description, note, reassuranceNote, ctaText} =
  Astro.props;
---

<section id="reservation" class="section-pad bg-surface-muted">
  <div class="container-page">
    <div
      class="card-soft mx-auto max-w-4xl overflow-hidden rounded-[2rem] p-8 sm:p-10 lg:p-14"
    >
      <div class="mx-auto flex max-w-2xl flex-col items-center text-center">
        <IconImage
          class="bg-brand-soft text-brand-strong"
          name="i-lucide-calendar-heart"
        />

        <h2 class="heading-lg">{title}</h2>
        <p class="body-lg mt-4 max-w-xl text-pretty">
          {description}
        </p>
        <div class="mt-3 space-y-1 text-sm leading-6 text-ink/68">
          <p>{note}</p>
          {reassuranceNote ? <p>{reassuranceNote}</p> : null}
        </div>

        <a
          href={bookingUrl}
          class="btn-primary mt-8 min-w-[13rem]"
          data-analytics-event="reserve_click"
        >
          {ctaText}
        </a>
      </div>
    </div>
  </div>
</section>
