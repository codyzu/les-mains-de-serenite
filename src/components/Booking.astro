---
import type {SiteData} from '../data/site';
import IconImage from './IconImage.astro';

type Props = Pick<SiteData, 'bookingUrl'>;

const {bookingUrl} = Astro.props;
---

<section id="reservation" class="section-pad bg-surface-muted">
  <div class="container-page">
    <div
      class="card-soft mx-auto max-w-4xl overflow-hidden rounded-[2rem] p-8 sm:p-10 lg:p-14"
    >
      <div class="mx-auto flex max-w-2xl flex-col items-center text-center">
        <IconImage
          class="bg-brand-soft text-brand-strong"
          name="i-lucide-calendar-heart"
        />

        <h2 class="heading-lg">Réserver un massage</h2>
        <p class="body-lg mt-4 max-w-xl">
          Réservez facilement votre massage en ligne et choisissez le créneau
          qui vous convient.
        </p>

        <a
          href={bookingUrl}
          onclick="window.dispatchEvent(new CustomEvent('cf-analytics-event', {detail: {name: 'book_click'}}))"
          target="_blank"
          rel="noreferrer noopener"
          class="btn-primary mt-8 min-w-[13rem]"
        >
          Réserver en ligne
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const el = document.querySelector('#reservation');

  if (el && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          window.dispatchEvent(
            new CustomEvent('cf-analytics-event', {
              detail: {name: 'view_booking_section'},
            })
          );
          observer.disconnect();
        }
      },
      {threshold: 0.5}
    );

    observer.observe(el);
  }
</script>
