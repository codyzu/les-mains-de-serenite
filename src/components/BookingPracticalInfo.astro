---
import type {BookingPracticalInfoData} from '../data/site';

type Props = BookingPracticalInfoData;

const {title, description, paymentTitle, paymentDescription} = Astro.props;
---

<div
  data-booking-reassurance
  class="mx-auto mt-4 grid max-w-4xl rounded-2xl border border-surface-soft bg-white/65 p-4 text-left sm:grid-cols-2 sm:p-5"
>
  <div class="sm:pr-5">
    <h3 class="text-sm font-semibold leading-6 text-ink">
      {title}
    </h3>
    <p class="mt-1 text-base leading-6 text-ink-muted">
      {description}
    </p>
  </div>

  <div
    class="mt-4 border-t border-surface-soft pt-4 sm:mt-0 sm:border-l sm:border-t-0 sm:pl-5 sm:pt-0"
  >
    <h3 class="text-sm font-semibold leading-6 text-ink">
      {paymentTitle}
    </h3>
    <p class="mt-1 text-base leading-6 text-ink-muted">
      {paymentDescription}
    </p>
  </div>
</div>
