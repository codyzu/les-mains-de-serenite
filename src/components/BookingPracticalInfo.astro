---
import type {BookingPracticalInfoData} from '../data/site';

type Props = BookingPracticalInfoData;

const {title, summary, detailsLabel, details} = Astro.props;
---

<div
  data-booking-practical-info
  class="mx-auto mt-4 max-w-3xl border-y border-surface-soft py-3 text-left sm:mt-5 sm:py-4"
>
  <h3 class="text-sm font-semibold leading-6 text-ink">{title}</h3>
  <p class="mt-1 text-sm leading-6 text-ink-muted sm:text-base">{summary}</p>

  <details class="group mt-1">
    <summary
      class="inline-flex min-h-11 cursor-pointer items-center py-2 text-sm font-medium text-brand-strong underline decoration-brand-muted underline-offset-4 transition hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-strong focus-visible:ring-offset-2 focus-visible:ring-offset-surface-muted"
    >
      {detailsLabel}
    </summary>
    <p class="mb-1 mt-1 text-sm leading-6 text-ink-muted">{details}</p>
  </details>
</div>
