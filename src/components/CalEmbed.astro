---
interface Props {
  calLink: string;
  resetLabel: string;
  resetStatus: string;
}

const {calLink, resetLabel, resetStatus} = Astro.props;
const namespace = calLink
  .replaceAll('/', '-')
  .replaceAll(/[^a-z\d-]/gi, '')
  .toLowerCase();
const mountId = `cal-inline-${namespace}`;
const directUrl = new URL(calLink.replace(/^\/+/, ''), 'https://www.cal.eu/');
---

<div
  data-cal-embed
  class="cal-embed"
  data-cal-embed-link={calLink}
  data-cal-namespace={namespace}
  data-cal-reset-status={resetStatus}
>
  <div class="flex px-1">
    <button
      data-cal-reset
      disabled
      hidden
      class="mb-3 inline-flex min-h-11 items-center gap-2 rounded-full px-3 py-2 text-sm font-medium text-ink-muted transition hover:bg-brand-soft/45 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-strong focus-visible:ring-offset-2 focus-visible:ring-offset-surface-muted disabled:cursor-wait disabled:opacity-50 sm:mb-4"
      type="button"
    >
      <span aria-hidden="true">←</span>
      <span>{resetLabel}</span>
    </button>
  </div>

  <div
    data-cal-shell
    class="relative min-h-[34rem] w-full overflow-hidden rounded-spa bg-white sm:min-h-[44rem]"
  >
    <div
      data-cal-mount
      class="min-h-[34rem] w-full sm:min-h-[44rem]"
      id={mountId}
      role="region"
      aria-label="Sélecteur de rendez-vous en ligne / Online appointment selector"
      tabindex="-1"
    >
    </div>

    <div
      data-cal-loading
      class="cal-embed-loading absolute inset-0 z-1 flex items-center justify-center bg-white"
      role="status"
      aria-live="polite"
    >
      <div class="flex flex-col items-center gap-4 px-6 text-center">
        <span
          class="h-9 w-9 animate-spin rounded-full border-3 border-brand-soft border-t-brand-strong"
          aria-hidden="true"></span>
        <span data-cal-loading-label class="text-sm font-medium text-ink-muted">
          <span lang="fr">Chargement des rendez-vous…</span>
          <span lang="en">Loading appointments…</span>
        </span>
      </div>
    </div>

    <div
      data-cal-fallback
      class="absolute inset-0 z-2 hidden items-center justify-center bg-white px-6 text-center"
      role="alert"
    >
      <div class="max-w-lg">
        <p class="text-base leading-7 text-ink">
          <span lang="fr">
            Le module de réservation ne peut pas s’afficher pour le moment.
          </span>
          <span lang="en">
            The booking calendar cannot be displayed at the moment.
          </span>
        </p>
        <a class="btn-primary mt-5" href={directUrl.toString()} rel="external">
          <span lang="fr">Réserver directement sur Cal.eu</span>
          <span lang="en">Book directly on Cal.eu</span>
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  :global(html[lang^='fr']) .cal-embed [lang='en'],
  :global(html[lang^='en']) .cal-embed [lang='fr'] {
    display: none;
  }
</style>

<script>
  import {designTokens} from '../styles/design-tokens';

  type CalArgs = unknown[];
  type QueuedCalApi = {
    (...args: CalArgs): void;
    q?: CalArgs[];
  };
  type CalApi = QueuedCalApi & {
    ns: Record<string, QueuedCalApi>;
    loaded?: boolean;
  };
  type EmbedState = {
    bookingTracked: boolean;
    bookerTransitionStartedAt?: number;
    listenersRegistered: boolean;
    mount: HTMLElement;
    readyTimer?: number;
    resetButton: HTMLButtonElement;
    root: HTMLElement;
    selectorUrl?: string;
  };
  type CalWindow = Window & {
    Cal?: CalApi;
    gtag?: (...args: unknown[]) => void;
    __calEmbedElements?: WeakSet<HTMLElement>;
    __calEmbedStates?: Map<string, EmbedState>;
  };

  const calScriptUrl = 'https://app.cal.eu/embed/embed.js';
  const calOrigin = 'https://www.cal.eu';
  const bookerTransitionTimeout = 30_000;
  const {colors, radius} = designTokens;
  // Cal embed CSS variables omit the "--" prefix. The authoritative list is
  // Cal's “Customize the embed with CSS variables” documentation; these
  // values intentionally map to the shared Les Mains de Sérénité design tokens.
  const calLightTheme = {
    'cal-brand': colors.brand.strong,
    'cal-brand-emphasis': colors.ink.base,
    'cal-brand-text': colors.white,
    'cal-brand-subtle': colors.brand.soft,
    'cal-brand-accent': colors.white,
    'cal-text': colors.ink.base,
    'cal-text-emphasis': colors.ink.base,
    'cal-text-subtle': colors.ink.muted,
    'cal-text-muted': colors.ink.subtle,
    'cal-text-inverted': colors.white,
    'cal-bg': colors.white,
    'cal-bg-emphasis': colors.brand.soft,
    'cal-bg-subtle': colors.surface.base,
    'cal-bg-muted': colors.surface.muted,
    'cal-bg-inverted': colors.ink.base,
    'cal-border': colors.brand.soft,
    'cal-border-emphasis': colors.brand.strong,
    'cal-border-subtle': colors.surface.soft,
    'cal-border-muted': colors.surface.muted,
    'cal-border-booker': colors.brand.soft,
    'cal-border-booker-width': '1px',
    radius: radius.control,
  };
  const calWindow = window as CalWindow;
  const initializedElements =
    calWindow.__calEmbedElements ?? new WeakSet<HTMLElement>();
  const embedStates =
    calWindow.__calEmbedStates ?? new Map<string, EmbedState>();

  calWindow.__calEmbedElements = initializedElements;
  calWindow.__calEmbedStates = embedStates;

  const queueCall = (target: QueuedCalApi, args: CalArgs) => {
    target.q = target.q || [];
    target.q.push(args);
  };

  const showFallback = (state: EmbedState) => {
    const loading = state.root.querySelector<HTMLElement>('[data-cal-loading]');
    const fallback = state.root.querySelector<HTMLElement>(
      '[data-cal-fallback]'
    );

    loading?.classList.add('hidden');
    fallback?.classList.remove('hidden');
    fallback?.classList.add('flex');
    state.resetButton.hidden = true;
    state.resetButton.disabled = true;
    state.root.dataset.calState = 'failed';
  };

  const showEmbed = (state: EmbedState) => {
    const iframe = state.mount.querySelector<HTMLIFrameElement>('iframe');

    state.selectorUrl = state.selectorUrl ?? iframe?.src;
    state.root
      .querySelector<HTMLElement>('[data-cal-loading]')
      ?.classList.add('hidden');
    state.resetButton.disabled = false;
    state.root.dataset.calState = 'ready';
  };

  const showLoading = (state: EmbedState, isReset: boolean) => {
    const loading = state.root.querySelector<HTMLElement>('[data-cal-loading]');
    const fallback = state.root.querySelector<HTMLElement>(
      '[data-cal-fallback]'
    );
    const loadingLabel = state.root.querySelector<HTMLElement>(
      '[data-cal-loading-label]'
    );

    fallback?.classList.add('hidden');
    fallback?.classList.remove('flex');
    loading?.classList.remove('hidden');
    state.resetButton.hidden = true;
    state.resetButton.disabled = true;
    state.root.dataset.calState = 'loading';

    if (isReset && loadingLabel) {
      loadingLabel.textContent = state.root.dataset.calResetStatus ?? '';
    }
  };

  const scrollToBookingSection = (state: EmbedState) => {
    const transitionStartedAt = state.bookerTransitionStartedAt;

    state.bookerTransitionStartedAt = undefined;

    if (
      transitionStartedAt === undefined ||
      performance.now() - transitionStartedAt > bookerTransitionTimeout
    ) {
      return;
    }

    const bookingSection = state.root.closest<HTMLElement>(
      '[data-booking-selector]'
    );

    if (!bookingSection) {
      return;
    }

    // bookerReady is public Cal API. Two frames let its accompanying iframe
    // resize reach the parent layout before correcting the document position.
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        const reducedMotion = window.matchMedia(
          '(prefers-reduced-motion: reduce)'
        ).matches;
        const behavior = reducedMotion ? 'auto' : 'smooth';
        const isMobile = window.matchMedia('(max-width: 639px)').matches;
        const headerBottom = Math.max(
          document
            .querySelector<HTMLElement>('[data-site-header]')
            ?.getBoundingClientRect().bottom ?? 0,
          0
        );

        if (isMobile) {
          const mountTop = state.mount.getBoundingClientRect().top;
          const desiredMountTop = headerBottom + 8;

          if (Math.abs(mountTop - desiredMountTop) < 2) {
            return;
          }

          window.scrollTo({
            behavior,
            top: Math.max(window.scrollY + mountTop - desiredMountTop, 0),
          });
          return;
        }

        const sectionTop = bookingSection.getBoundingClientRect().top;

        if (sectionTop >= headerBottom && sectionTop < window.innerHeight) {
          return;
        }

        bookingSection.scrollIntoView({
          behavior,
          block: 'start',
        });
      });
    });
  };

  const ensureCal = (): CalApi => {
    if (calWindow.Cal) {
      return calWindow.Cal;
    }

    const cal = ((...args: CalArgs) => {
      if (args[0] === 'init') {
        const namespace = args[1];

        if (typeof namespace === 'string') {
          const namespaceApi: QueuedCalApi = (...namespaceArgs: CalArgs) => {
            queueCall(namespaceApi, namespaceArgs);
          };

          cal.ns[namespace] = cal.ns[namespace] || namespaceApi;
          queueCall(cal.ns[namespace], args);
          queueCall(cal, ['initNamespace', namespace]);
          return;
        }
      }

      queueCall(cal, args);
    }) as CalApi;

    cal.ns = {};
    cal.loaded = true;
    calWindow.Cal = cal;

    const script = document.createElement('script');
    script.src = calScriptUrl;
    script.async = true;
    script.dataset.calEmbedLoader = '';
    script.addEventListener('error', () => {
      for (const state of embedStates.values()) {
        showFallback(state);
      }
    });
    document.head.append(script);

    return cal;
  };

  const mountEmbed = (root: HTMLElement) => {
    const {calEmbedLink: calLink, calNamespace: namespace} = root.dataset;
    const mount = root.querySelector<HTMLElement>('[data-cal-mount]');
    const resetButton =
      root.querySelector<HTMLButtonElement>('[data-cal-reset]');

    if (!calLink || !namespace || !mount || !resetButton) {
      return;
    }

    const previousState = embedStates.get(namespace);
    const state: EmbedState = {
      bookingTracked: false,
      listenersRegistered: previousState?.listenersRegistered ?? false,
      mount,
      resetButton,
      root,
      selectorUrl: previousState?.selectorUrl,
    };

    window.clearTimeout(previousState?.readyTimer);
    embedStates.set(namespace, state);
    showLoading(state, false);
    mount.replaceChildren();

    try {
      const cal = ensureCal();

      if (!cal.ns[namespace]) {
        cal('init', namespace, {origin: calOrigin});
      }

      const namespacedCal = cal.ns[namespace];

      if (!namespacedCal) {
        showFallback(state);
        return;
      }

      if (!state.listenersRegistered) {
        namespacedCal('on', {
          action: 'eventTypeSelected',
          callback: () => {
            const currentState = embedStates.get(namespace);

            if (currentState) {
              currentState.bookerTransitionStartedAt = performance.now();
              currentState.resetButton.hidden = false;
            }
          },
        });
        namespacedCal('on', {
          action: 'bookerReady',
          callback: () => {
            const currentState = embedStates.get(namespace);

            if (currentState) {
              scrollToBookingSection(currentState);
            }
          },
        });
        namespacedCal('on', {
          action: 'linkReady',
          callback: () => {
            const currentState = embedStates.get(namespace);

            if (currentState) {
              window.clearTimeout(currentState.readyTimer);
              showEmbed(currentState);
            }
          },
        });
        namespacedCal('on', {
          action: 'linkFailed',
          callback: () => {
            const currentState = embedStates.get(namespace);

            if (currentState) {
              window.clearTimeout(currentState.readyTimer);
              showFallback(currentState);
            }
          },
        });
        namespacedCal('on', {
          action: 'bookingSuccessfulV2',
          callback: () => {
            const currentState = embedStates.get(namespace);

            if (currentState?.bookingTracked) {
              return;
            }

            if (currentState) {
              currentState.bookingTracked = true;
            }

            if (typeof calWindow.gtag === 'function') {
              calWindow.gtag('event', 'booking_completed', {
                booking_surface: 'embedded_selector',
                cal_link: calLink,
              });
            }
          },
        });
        state.listenersRegistered = true;
      }

      namespacedCal('inline', {
        elementOrSelector: `#${mount.id}`,
        calLink,
        config: {
          layout: 'month_view',
          // Keep mobile time slots in the auto-sized inline layout. Cal's
          // alternate small-screen slots view is an internally scrolling pane.
          useSlotsViewOnSmallScreen: false,
        },
      });
      state.selectorUrl =
        state.selectorUrl ??
        mount.querySelector<HTMLIFrameElement>('iframe')?.src;

      namespacedCal('ui', {
        theme: 'light',
        hideEventTypeDetails: true,
        showTimezoneWhenEventDetailsHidden: true,
        cssVarsPerTheme: {
          light: calLightTheme,
        },
      });

      state.readyTimer = window.setTimeout(() => showFallback(state), 20_000);
    } catch {
      showFallback(state);
    }
  };

  const resetEmbed = (root: HTMLElement) => {
    const {calEmbedLink: calLink, calNamespace: namespace} = root.dataset;
    const mount = root.querySelector<HTMLElement>('[data-cal-mount]');
    const state = namespace ? embedStates.get(namespace) : undefined;
    const iframe = mount?.querySelector<HTMLIFrameElement>('iframe');
    const selectorUrl = state?.selectorUrl ?? iframe?.src;

    if (!calLink || !namespace || !mount || !state || !iframe || !selectorUrl) {
      window.location.reload();
      return;
    }

    if (typeof calWindow.gtag === 'function') {
      calWindow.gtag('event', 'booking_selector_reset', {
        booking_surface: 'embedded_selector',
        cal_link: calLink,
      });
    }

    window.clearTimeout(state.readyTimer);
    state.bookingTracked = false;
    state.bookerTransitionStartedAt = undefined;
    showLoading(state, true);
    iframe.src = selectorUrl;
    state.readyTimer = window.setTimeout(() => showFallback(state), 20_000);
    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    root.scrollIntoView({
      behavior: reducedMotion ? 'auto' : 'smooth',
      block: 'start',
    });
    mount.focus({preventScroll: true});
  };

  const initializeEmbed = (root: HTMLElement) => {
    if (initializedElements.has(root)) {
      return;
    }

    initializedElements.add(root);
    root
      .querySelector<HTMLButtonElement>('[data-cal-reset]')
      ?.addEventListener('click', () => resetEmbed(root));
    mountEmbed(root);
  };

  const initializeEmbeds = () => {
    for (const mount of document.querySelectorAll<HTMLElement>(
      '[data-cal-embed]'
    )) {
      initializeEmbed(mount);
    }
  };

  initializeEmbeds();
  document.addEventListener('astro:page-load', initializeEmbeds);
</script>

<!--
  Later phases can pass a private link as calLink (for example,
  "lesmainsdeserenite/private-event"); its namespace is derived internally.
  Private appointment pages are intentionally deferred. booking_completed is the
  shared GA4 key event imported into Google Ads.
-->
