---
import type {SiteData} from '../data/site';
import {getPhoneHref} from '../utils/phone';
import IconImage from './IconImage.astro';
import SectionIntro from './SectionIntro.astro';

type Props = Pick<SiteData, 'phone' | 'email' | 'locationText'>;

const {phone, email, locationText} = Astro.props;
const phoneHref = getPhoneHref(phone);
---

<section id="contact" class="section-pad bg-surface">
  <div class="container-page">
    <SectionIntro
      title="Contact"
      text="Une question, une demande particulière, ou envie de réserver directement par téléphone?"
    />

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      <article class="card-soft p-6 sm:p-7">
        <IconImage
          class="bg-brand-soft text-brand-strong"
          name="i-lucide-phone"
        />
        <h3 class="heading-md text-[1.6rem]">Téléphone</h3>
        <a
          href={`tel:${phoneHref}`}
          onclick="window.dispatchEvent(new CustomEvent('cf-analytics-event', {detail: {name: 'phone_click'}}))"
          class="body-lg mt-4 inline-flex text-ink transition hover:text-brand-strong"
        >
          {phone}
        </a>
      </article>

      <article class="card-soft p-6 sm:p-7">
        <IconImage
          class="bg-accent-soft text-accent-strong"
          name="i-lucide-mail"
        />
        <h3 class="heading-md text-[1.6rem]">Email</h3>
        <a
          href={`mailto:${email}`}
          onclick="window.dispatchEvent(new CustomEvent('cf-analytics-event', {detail: {name: 'email_click'}}))"
          class="body-lg mt-4 inline-flex break-all text-ink transition hover:text-accent-strong"
        >
          {email}
        </a>
      </article>

      <article class="card-soft p-6 sm:p-7 md:col-span-2 xl:col-span-1">
        <IconImage
          class="bg-brand-soft text-brand-strong"
          name="i-lucide-map-pin"
        />
        <h3 class="heading-md text-[1.6rem]">Lieu</h3>
        <p class="body-base mt-4">{locationText}</p>
      </article>
    </div>
  </div>
</section>
