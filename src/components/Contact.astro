---
import type {ContactBlockData} from '../data/site';
import {formatPhoneDisplay, getPhoneHref} from '../utils/phone';
import IconImage from './IconImage.astro';
import SectionIntro from './SectionIntro.astro';

type Props = ContactBlockData & {
  phone: string;
  email: string;
  whatsappUrl: string;
  whatsappHref?: string;
  compact?: boolean;
};

const {
  phone,
  email,
  whatsappUrl,
  locationText,
  title,
  subtitle,
  whatsappTitle,
  phoneTitle,
  emailTitle,
  locationTitle,
  whatsappDescription,
  phoneDescription,
  emailDescription,
  whatsappLabel,
  whatsappEmphasis = false,
  whatsappHref,
  compact = false,
} = Astro.props;
const phoneHref = getPhoneHref(phone);
const phoneDisplay = formatPhoneDisplay(phone);
const effectiveWhatsappHref = whatsappHref ?? whatsappUrl;
const hasLocation = Boolean(locationText);
---

<section
  id="contact"
  class:list={[
    'section-pad bg-surface',
    compact && '!py-12 sm:!py-16 lg:!py-18',
  ]}
>
  <div class="container-page">
    <SectionIntro title={title} text={subtitle} compact={compact} />

    <div
      class:list={[
        'grid grid-cols-1 sm:grid-cols-2',
        compact ? 'gap-4 sm:gap-5' : 'gap-6',
        hasLocation ? 'xl:grid-cols-4' : 'xl:grid-cols-3',
      ]}
    >
      <article
        class:list={[
          'card-soft min-w-0',
          compact ? 'p-5 sm:p-6' : 'p-6 sm:p-7',
          whatsappEmphasis && 'border-brand-muted bg-brand-soft/30 shadow-soft',
        ]}
      >
        <IconImage
          class="bg-brand-soft text-brand-strong"
          name="i-lucide-message-circle-heart"
        />
        <h3 class="heading-md text-[1.6rem]">{whatsappTitle}</h3>
        {
          whatsappDescription ? (
            <p class="body-base mt-3">{whatsappDescription}</p>
          ) : null
        }
        <a
          href={effectiveWhatsappHref}
          target="_blank"
          rel="noreferrer"
          class:list={[
            'mt-4 inline-flex transition',
            whatsappEmphasis
              ? 'rounded-full bg-brand px-5 py-2.5 text-sm font-medium text-white shadow-soft hover:bg-brand-strong'
              : 'body-lg text-ink hover:text-brand-strong',
          ]}
          data-analytics-event="whatsapp_click"
        >
          {whatsappLabel}
        </a>
      </article>

      <article
        class:list={[
          'card-soft min-w-0',
          compact ? 'p-5 sm:p-6' : 'p-6 sm:p-7',
        ]}
      >
        <IconImage
          class="bg-brand-soft text-brand-strong"
          name="i-lucide-phone"
        />
        <h3 class="heading-md text-[1.6rem]">{phoneTitle}</h3>
        {
          phoneDescription ? (
            <p class="body-base mt-3">{phoneDescription}</p>
          ) : null
        }
        <a
          href={`tel:${phoneHref}`}
          class="body-lg mt-4 inline-flex text-ink transition hover:text-brand-strong"
          data-analytics-event="phone_click"
        >
          {phoneDisplay}
        </a>
      </article>

      <article
        class:list={[
          'card-soft min-w-0',
          compact ? 'p-5 sm:p-6' : 'p-6 sm:p-7',
        ]}
      >
        <IconImage
          class="bg-accent-soft text-accent-strong"
          name="i-lucide-mail"
        />
        <h3 class="heading-md text-[1.6rem]">{emailTitle}</h3>
        {
          emailDescription ? (
            <p class="body-base mt-3">{emailDescription}</p>
          ) : null
        }
        <a
          href={`mailto:${email}`}
          class="body-lg mt-4 inline-flex break-all text-ink transition hover:text-accent-strong"
          data-analytics-event="email_click"
        >
          {email}
        </a>
      </article>

      {
        hasLocation ? (
          <article
            class:list={[
              'card-soft min-w-0',
              compact ? 'p-5 sm:p-6' : 'p-6 sm:p-7',
            ]}
          >
            <IconImage
              class="bg-brand-soft text-brand-strong"
              name="i-lucide-map-pin"
            />
            <h3 class="heading-md text-[1.6rem]">{locationTitle}</h3>
            <p class="body-base mt-4">{locationText}</p>
          </article>
        ) : null
      }
    </div>
  </div>
</section>
