---
import type {ContactBlockData} from '../data/site';
import {getPhoneHref} from '../utils/phone';
import IconImage from './IconImage.astro';
import SectionIntro from './SectionIntro.astro';

type Props = ContactBlockData & {
  phone: string;
  email: string;
  whatsappUrl: string;
  whatsappHref?: string;
};

const {
  phone,
  email,
  whatsappUrl,
  locationText,
  title,
  subtitle,
  whatsappDescription,
  phoneDescription,
  emailDescription,
  whatsappLabel,
  whatsappHref,
} = Astro.props;
const phoneHref = getPhoneHref(phone);
const effectiveWhatsappHref = whatsappHref ?? whatsappUrl;
const hasLocation = Boolean(locationText);
---

<section id="contact" class="section-pad bg-surface">
  <div class="container-page">
    <SectionIntro title={title} text={subtitle} />

    <div
      class:list={[
        'grid grid-cols-1 gap-6 sm:grid-cols-2',
        hasLocation ? 'xl:grid-cols-4' : 'xl:grid-cols-3',
      ]}
    >
      <article class="card-soft min-w-0 p-6 sm:p-7">
        <IconImage
          class="bg-brand-soft text-brand-strong"
          name="i-lucide-message-circle-heart"
        />
        <h3 class="heading-md text-[1.6rem]">WhatsApp</h3>
        {
          whatsappDescription ? (
            <p class="body-base mt-3">{whatsappDescription}</p>
          ) : null
        }
        <a
          href={effectiveWhatsappHref}
          target="_blank"
          rel="noreferrer"
          class="body-lg mt-4 inline-flex text-ink transition hover:text-brand-strong"
        >
          {whatsappLabel}
        </a>
      </article>

      <article class="card-soft min-w-0 p-6 sm:p-7">
        <IconImage
          class="bg-brand-soft text-brand-strong"
          name="i-lucide-phone"
        />
        <h3 class="heading-md text-[1.6rem]">Téléphone</h3>
        {
          phoneDescription ? (
            <p class="body-base mt-3">{phoneDescription}</p>
          ) : null
        }
        <a
          href={`tel:${phoneHref}`}
          class="body-lg mt-4 inline-flex text-ink transition hover:text-brand-strong"
        >
          {phone}
        </a>
      </article>

      <article class="card-soft min-w-0 p-6 sm:p-7">
        <IconImage
          class="bg-accent-soft text-accent-strong"
          name="i-lucide-mail"
        />
        <h3 class="heading-md text-[1.6rem]">Email</h3>
        {
          emailDescription ? (
            <p class="body-base mt-3">{emailDescription}</p>
          ) : null
        }
        <a
          href={`mailto:${email}`}
          class="body-lg mt-4 inline-flex break-all text-ink transition hover:text-accent-strong"
        >
          {email}
        </a>
      </article>

      {
        hasLocation ? (
          <article class="card-soft min-w-0 p-6 sm:p-7">
            <IconImage
              class="bg-brand-soft text-brand-strong"
              name="i-lucide-map-pin"
            />
            <h3 class="heading-md text-[1.6rem]">Lieu</h3>
            <p class="body-base mt-4">{locationText}</p>
          </article>
        ) : null
      }
    </div>
  </div>
</section>
