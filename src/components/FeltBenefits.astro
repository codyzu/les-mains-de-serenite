---
import type {FeltBenefitsData} from '../data/site';
import SectionIntro from './SectionIntro.astro';

type Props = FeltBenefitsData;

const {title, intro, items} = Astro.props;
---

<section id="bienfaits" class="section-pad bg-surface">
  <div class="container-page">
    <SectionIntro title={title} text={intro} />

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
      {
        items.map((item) => (
          <article class="card-soft flex h-full items-center justify-center p-5 text-center sm:p-6">
            <p class="text-base font-medium leading-6 text-ink">{item}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
