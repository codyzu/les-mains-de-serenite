---
import type {SiteData} from '../data/site';
import SectionIntro from './SectionIntro.astro';

type Props = SiteData['feltBenefits'];

const {title, items} = Astro.props;
---

<section id="bienfaits" class="section-pad bg-surface">
  <div class="container-page">
    <SectionIntro
      title={title}
      text="Des bienfaits souvent ressentis dès la fin de la séance."
    />

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
      {
        items.map((item) => (
          <article class="card-soft flex h-full items-center justify-center p-5 text-center sm:p-6">
            <p class="text-base font-medium leading-6 text-ink">{item}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
