---
import {defaultLocale, getLocalizedSite, site, type Locale} from '../data/site';
import {getBaseUrl} from '../utils/url';

type Props = {
  locale?: Locale;
  reserveLink?: string;
  reserveActive?: boolean;
};

const {
  locale = defaultLocale,
  reserveLink,
  reserveActive = false,
} = Astro.props;
const baseUrl = getBaseUrl();
const toHref = (path: string) =>
  path.startsWith('http') ? path : `${baseUrl}${path.replace(/^\//, '')}`;
const homePath = locale === 'en' ? '/en/' : '/';
const homeHref = toHref(homePath);
const bookingHref = reserveLink
  ? toHref(reserveLink)
  : `${homeHref}#reservation`;
const {
  business: {name: brand},
  pages,
} = site;
const {
  chrome: {footer},
} = getLocalizedSite(locale);
const {tagline, links} = footer;
---

<footer
  class="bg-brand-strong pb-[calc(2.5rem+env(safe-area-inset-bottom))] pt-10 text-white"
>
  <div class="container-page flex flex-col items-center gap-3 text-center">
    <div class="font-display text-3xl">{brand}</div>
    <p class="text-white/85">{tagline}</p>
    <div
      class="flex flex-wrap items-center justify-center gap-4 text-sm text-white/75"
    >
      <a href={`${homeHref}#massages`} class="no-underline hover:text-white">
        {links.massages}
      </a>
      <a href={`${homeHref}#apropos`} class="no-underline hover:text-white">
        {links.about}
      </a>
      {
        reserveActive ? (
          <span aria-current="page" class="text-white">
            {links.reserve}
          </span>
        ) : (
          <a href={bookingHref} class="no-underline hover:text-white">
            {links.reserve}
          </a>
        )
      }
      <a href={`${homeHref}#contact`} class="no-underline hover:text-white">
        {links.contact}
      </a>
      <a
        href={toHref(`${pages.mentionsLegalesPath}/`)}
        class="no-underline hover:text-white"
      >
        {links.legal}
      </a>
      <a
        href={toHref(`${pages.politiqueConfidentialitePath}/`)}
        class="no-underline hover:text-white"
      >
        {links.privacy}
      </a>
    </div>
  </div>
</footer>
