---
import {Image} from 'astro:assets';
import {
  defaultLocale,
  getLocalizedSite,
  site,
  type Locale,
  type LocalePathMap,
} from '../data/site';
import LogoSquareDark from '../assets/logo-square-dark.png';
import {getPhoneHref} from '../utils/phone';
import {getBaseUrl} from '../utils/url';

type Props = {
  locale?: Locale;
  languageSwitchPaths?: LocalePathMap;
  reserveLink?: string;
  reserveActive?: boolean;
};

const {
  locale = defaultLocale,
  languageSwitchPaths,
  reserveLink,
  reserveActive = false,
} = Astro.props;
const baseUrl = getBaseUrl();
const toHref = (path: string) =>
  path.startsWith('http') ? path : `${baseUrl}${path.replace(/^\//, '')}`;
const homePath = locale === 'en' ? '/en/' : '/';
const homeHref = toHref(homePath);
const bookingHref = reserveLink
  ? toHref(reserveLink)
  : `${homeHref}#reservation`;
const brand = site.business.name;
const localized = getLocalizedSite(locale);
const {
  chrome: {header},
  pages: {home, maderotherapie, program},
} = localized;
const {tagline, links} = header;
const {
  hero: {primaryCta, secondaryCta, whatsappCta},
  booking: {bookingPath},
  whatsapp: {generalHref: whatsappHref},
} = home;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const normalizedHomePath = homePath.replace(/\/$/, '') || '/';
const programPath = program.path.replace(/\/$/, '') || '/';
const maderotherapiePath = maderotherapie.path.replace(/\/$/, '') || '/';
const homeActive = currentPath === normalizedHomePath;
const programActive = currentPath === programPath;
const maderotherapieActive = currentPath === maderotherapiePath;
const programHref = toHref(program.path);
const maderotherapieHref = toHref(maderotherapie.path);
const drawerBookingHref = reserveLink
  ? toHref(reserveLink)
  : toHref(bookingPath);
const phoneHref = getPhoneHref(site.business.phone);
const menuLabel = locale === 'en' ? 'Menu' : 'Menu';
const closeMenuLabel = locale === 'en' ? 'Close menu' : 'Fermer le menu';
const navLabel = locale === 'en' ? 'Main navigation' : 'Navigation principale';
---

<header
  class="sticky top-0 z-50 border-b border-surface-soft/80 bg-surface-muted/90 backdrop-blur-md"
>
  <div
    class="container-page flex items-center justify-between gap-4 pb-4 pt-[calc(1rem+env(safe-area-inset-top))] sm:gap-8"
  >
    <a
      href={homeHref}
      class="flex min-w-0 items-center gap-2 no-underline sm:gap-3"
    >
      <Image
        src={LogoSquareDark}
        width={288}
        height={288}
        alt=""
        class="h-10 w-10 shrink-0 select-none sm:h-12 sm:w-12"
        loading="eager"
        decoding="async"
        fetchpriority="auto"
        aria-hidden="true"
      />
      <div class="min-w-0">
        <div
          class="font-display text-xl leading-tight text-ink sm:text-2xl lg:truncate"
        >
          {brand}
        </div>
        <p
          class="mt-0.5 truncate text-xs font-normal leading-tight text-ink-muted max-xs:hidden sm:text-sm"
        >
          {tagline}
        </p>
      </div>
    </a>

    <nav class="hidden items-center gap-6 lg:flex">
      <a href={`${homeHref}#accueil`} class="nav-link">{links.home}</a>
      <a href={`${homeHref}#massages`} class="nav-link">{links.massages}</a>
      {
        maderotherapieActive ? (
          <span aria-current="page" class="text-sm font-medium text-ink">
            {links.maderotherapie}
          </span>
        ) : (
          <a href={maderotherapieHref} class="nav-link">
            {links.maderotherapie}
          </a>
        )
      }
      {
        programActive ? (
          <span aria-current="page" class="text-sm font-medium text-ink">
            {links.program}
          </span>
        ) : (
          <a href={programHref} class="nav-link">
            {links.program}
          </a>
        )
      }
      <a href={`${homeHref}#apropos`} class="nav-link">{links.about}</a>
      {
        reserveActive ? (
          <span aria-current="page" class="text-sm font-medium text-ink">
            {links.reserve}
          </span>
        ) : (
          <a
            href={bookingHref}
            class="nav-link"
            data-analytics-event="reserve_click"
          >
            {links.reserve}
          </a>
        )
      }
      <a href={`${homeHref}#contact`} class="nav-link">{links.contact}</a>
    </nav>
    <div
      class="flex shrink-0 items-center gap-4 max-xs:flex-col max-xs:items-end max-xs:gap-1 lg:gap-3"
    >
      {
        languageSwitchPaths ? (
          <div
            data-language-switcher
            class="flex items-center gap-0.5 text-xs font-medium uppercase tracking-[0.1em]"
          >
            <a
              href={toHref(languageSwitchPaths.fr)}
              aria-current={locale === 'fr' ? 'page' : undefined}
              class:list={[
                'inline-flex h-8 min-w-8 touch-manipulation items-center justify-center rounded-full px-1.5 no-underline transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/55 focus-visible:ring-offset-1 focus-visible:ring-offset-surface-muted',
                locale === 'fr'
                  ? 'bg-brand-muted/35 font-semibold text-ink'
                  : 'text-ink-muted hover:bg-white/50 hover:text-ink active:bg-brand-muted/25',
              ]}
            >
              FR
            </a>
            <span aria-hidden="true" class="text-ink-subtle/70">
              /
            </span>
            <a
              href={toHref(languageSwitchPaths.en)}
              aria-current={locale === 'en' ? 'page' : undefined}
              class:list={[
                'inline-flex h-8 min-w-8 touch-manipulation items-center justify-center rounded-full px-1.5 no-underline transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/55 focus-visible:ring-offset-1 focus-visible:ring-offset-surface-muted',
                locale === 'en'
                  ? 'bg-brand-muted/35 font-semibold text-ink'
                  : 'text-ink-muted hover:bg-white/50 hover:text-ink active:bg-brand-muted/25',
              ]}
            >
              EN
            </a>
          </div>
        ) : null
      }
      <button
        data-mobile-menu-open
        type="button"
        class="inline-flex touch-manipulation select-none items-center rounded-full border border-brand-muted/70 bg-brand-muted/45 px-4 py-2 text-sm font-semibold text-ink shadow-card transition hover:bg-brand-muted/55 focus:outline-none focus:ring-2 focus:ring-brand/45 lg:hidden"
        aria-label={menuLabel}
        aria-controls="mobile-navigation-drawer"
        aria-expanded="false"
      >
        {menuLabel}
      </button>
    </div>
  </div>
</header>

<div
  inert
  data-mobile-menu
  class="fixed inset-0 z-60 hidden overflow-hidden lg:hidden"
  data-state="closed"
  aria-hidden="true"
>
  <div
    data-mobile-menu-backdrop
    class="absolute inset-0 bg-ink/25 opacity-0 transition-opacity duration-250"
    aria-hidden="true"
  >
  </div>
  <aside
    data-mobile-menu-drawer
    id="mobile-navigation-drawer"
    class="absolute right-0 top-0 flex h-[calc(100dvh-clamp(3.75rem,9.5dvh,7.5rem))] w-[88vw] max-w-[400px] flex-col overflow-y-auto rounded-l-spa bg-surface px-6 pb-7 pt-[calc(1.25rem+env(safe-area-inset-top))] text-ink shadow-soft"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-navigation-title"
  >
    <div class="flex items-start justify-between gap-5">
      <div>
        <p
          id="mobile-navigation-title"
          class="font-display text-2xl leading-tight text-ink"
        >
          {brand}
        </p>
        <p class="mt-1 text-sm text-ink-muted">{tagline}</p>
      </div>
      <button
        data-mobile-menu-close
        type="button"
        class="inline-flex h-10 w-10 touch-manipulation select-none shrink-0 items-center justify-center rounded-full border border-surface-soft/80 bg-white/50 text-ink-muted transition hover:bg-white/80 hover:text-ink focus:outline-none focus:ring-2 focus:ring-brand/45"
        aria-label={closeMenuLabel}
      >
        <span class="i-lucide-x h-4 w-4" aria-hidden="true"></span>
      </button>
    </div>

    <nav class="mt-8 flex flex-col gap-[0.4rem]" aria-label={navLabel}>
      {
        homeActive ? (
          <span aria-current="page" class="drawer-link drawer-link-active">
            {links.home}
          </span>
        ) : (
          <a href={`${homeHref}#accueil`} class="drawer-link">
            {links.home}
          </a>
        )
      }
      <a href={`${homeHref}#massages`} class="drawer-link">
        {links.massages}
      </a>
      {
        maderotherapieActive ? (
          <span aria-current="page" class="drawer-link drawer-link-active">
            {links.maderotherapie}
          </span>
        ) : (
          <a href={maderotherapieHref} class="drawer-link">
            {links.maderotherapie}
          </a>
        )
      }
      {
        programActive ? (
          <span aria-current="page" class="drawer-link drawer-link-active">
            {links.program}
          </span>
        ) : (
          <a href={programHref} class="drawer-link">
            {links.program}
          </a>
        )
      }
      <a href={`${homeHref}#apropos`} class="drawer-link">
        {links.about}
      </a>
      <a href={`${homeHref}#contact`} class="drawer-link">
        {links.contact}
      </a>
    </nav>

    <div class="mt-auto pt-8">
      <div>
        {
          reserveActive ? (
            <span aria-current="page" class="btn-primary w-full cursor-default">
              {primaryCta}
            </span>
          ) : (
            <a
              href={drawerBookingHref}
              class="btn-primary w-full no-underline"
              data-analytics-event="reserve_click"
            >
              {primaryCta}
            </a>
          )
        }
      </div>

      <div class="mt-3 grid grid-cols-2 gap-3">
        <a
          href={`tel:${phoneHref}`}
          class="inline-flex items-center justify-center rounded-full border border-brand-soft bg-white/60 px-4 py-3 text-sm font-medium text-ink no-underline transition hover:bg-white"
          data-analytics-event="phone_click"
        >
          {secondaryCta}
        </a>
        <a
          href={whatsappHref}
          class="inline-flex items-center justify-center rounded-full border border-brand-soft bg-white/60 px-4 py-3 text-sm font-medium text-ink no-underline transition hover:bg-white"
          data-analytics-event="whatsapp_click"
        >
          {whatsappCta}
        </a>
      </div>
    </div>
  </aside>
</div>

<script>
  const menuRoot = document.querySelector('[data-mobile-menu]');
  const menuDrawer = document.querySelector('[data-mobile-menu-drawer]');
  const menuBackdrop = document.querySelector('[data-mobile-menu-backdrop]');
  const openMenuButton = document.querySelector('[data-mobile-menu-open]');
  const closeMenuButton = document.querySelector('[data-mobile-menu-close]');
  const focusableSelector = [
    'a[href]',
    'button:not([disabled])',
    '[tabindex]:not([tabindex="-1"])',
  ].join(',');
  let previousFocus: Element | null = null;

  const getFocusableMenuItems = () =>
    menuDrawer
      ? [...menuDrawer.querySelectorAll<HTMLElement>(focusableSelector)].filter(
          (element) => !element.hasAttribute('disabled')
        )
      : [];

  const openMenu = () => {
    if (!menuRoot || !openMenuButton) {
      return;
    }

    previousFocus = document.activeElement;
    menuDrawer?.classList.remove('animate-slide-out-right');
    menuDrawer?.classList.add('animate-slide-in-right');
    menuRoot.classList.remove('hidden');
    menuRoot.setAttribute('data-state', 'open');
    menuRoot.removeAttribute('aria-hidden');
    menuRoot.removeAttribute('inert');
    document.body.setAttribute('data-mobile-menu-open', '');
    document.body.classList.add('overflow-hidden');
    openMenuButton.setAttribute('aria-expanded', 'true');
  };

  const finishClosingMenu = () => {
    if (menuRoot?.getAttribute('data-state') !== 'closing') {
      return;
    }

    menuRoot.classList.add('hidden');
    menuRoot.setAttribute('data-state', 'closed');
    document.body.removeAttribute('data-mobile-menu-open');
  };

  const closeMenu = () => {
    if (!menuRoot || !openMenuButton) {
      return;
    }

    menuRoot.setAttribute('data-state', 'closing');
    menuDrawer?.classList.remove('animate-slide-in-right');
    menuDrawer?.classList.add('animate-slide-out-right');
    menuRoot.setAttribute('aria-hidden', 'true');
    menuRoot.setAttribute('inert', '');
    document.body.classList.remove('overflow-hidden');
    openMenuButton.setAttribute('aria-expanded', 'false');

    if (previousFocus instanceof HTMLElement) {
      previousFocus.focus();
    }
  };

  openMenuButton?.addEventListener('click', openMenu);
  closeMenuButton?.addEventListener('click', closeMenu);
  menuBackdrop?.addEventListener('click', closeMenu);

  menuDrawer?.addEventListener('click', (event) => {
    if (event.target instanceof HTMLAnchorElement) {
      closeMenu();
    }
  });

  menuDrawer?.addEventListener('animationend', (event) => {
    if (
      event.animationName === 'slide-in-right' &&
      menuRoot?.getAttribute('data-state') === 'open'
    ) {
      closeMenuButton instanceof HTMLElement
        ? closeMenuButton.focus()
        : getFocusableMenuItems()[0]?.focus();
    } else if (event.animationName === 'slide-out-right') {
      finishClosingMenu();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (menuRoot?.getAttribute('data-state') !== 'open') {
      return;
    }

    if (event.key === 'Escape') {
      event.preventDefault();
      closeMenu();
      return;
    }

    if (event.key !== 'Tab') {
      return;
    }

    const focusableItems = getFocusableMenuItems();
    const firstItem = focusableItems[0];
    const lastItem = focusableItems.at(-1);

    if (!firstItem || !lastItem) {
      return;
    }

    if (!menuDrawer?.contains(document.activeElement)) {
      event.preventDefault();
      event.shiftKey ? lastItem.focus() : firstItem.focus();
      return;
    }

    if (event.shiftKey && document.activeElement === firstItem) {
      event.preventDefault();
      lastItem.focus();
    } else if (!event.shiftKey && document.activeElement === lastItem) {
      event.preventDefault();
      firstItem.focus();
    }
  });
</script>

<style>
  /* Keep drawer state styling close to the JS that toggles data-state. */
  [data-mobile-menu][data-state='open'] {
    pointer-events: auto;
  }

  [data-mobile-menu][data-state='open'] [data-mobile-menu-backdrop] {
    opacity: 1;
  }

  /* Keep the rounded edge clipped cleanly while Uno animates the drawer. */
  [data-mobile-menu-drawer] {
    -webkit-backface-visibility: hidden;
    animation-duration: 220ms;
    animation-timing-function: ease-out;
    backface-visibility: hidden;
    clip-path: inset(0 round 1.5rem 0 0 1.5rem);
  }

  [data-mobile-menu][data-state='closed'],
  [data-mobile-menu][data-state='closing'] {
    pointer-events: none;
  }

  :global(body[data-mobile-menu-open] > header),
  :global(body[data-mobile-menu-open] > main),
  :global(body[data-mobile-menu-open] > footer) {
    filter: blur(2px);
  }

  /* Header-only shortcuts keep repeated drawer links readable in markup. */
  .drawer-link {
    --uno: 'rounded-2xl px-4 py-[0.675rem] text-base font-medium text-ink-muted no-underline transition hover:bg-white/70 hover:text-ink focus:outline-none focus:ring-2 focus:ring-brand/45';
  }

  .drawer-link-active {
    --uno: 'border border-brand-soft/70 bg-brand-soft/45 text-ink';
  }

  @media (prefers-reduced-motion: reduce) {
    [data-mobile-menu-backdrop],
    [data-mobile-menu-drawer] {
      animation-duration: 1ms;
      transition-duration: 1ms;
    }
  }
</style>
