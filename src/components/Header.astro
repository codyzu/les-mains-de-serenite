---
import {
  defaultLocale,
  getLocalizedSite,
  site,
  type Locale,
  type LocalePathMap,
} from '../data/site';
import logoSquareSimpleSmall from '../assets/logo-icon-small-paths-dark.png';
import {getBaseUrl} from '../utils/url';

type Props = {
  locale?: Locale;
  languageSwitchPaths?: LocalePathMap;
  reserveLink?: string;
  reserveActive?: boolean;
};

const {
  locale = defaultLocale,
  languageSwitchPaths,
  reserveLink,
  reserveActive = false,
} = Astro.props;
const baseUrl = getBaseUrl();
const toHref = (path: string) =>
  path.startsWith('http') ? path : `${baseUrl}${path.replace(/^\//, '')}`;
const homePath = locale === 'en' ? '/en/' : '/';
const homeHref = toHref(homePath);
const bookingHref = reserveLink
  ? toHref(reserveLink)
  : `${homeHref}#reservation`;
const brand = site.business.name;
const localized = getLocalizedSite(locale);
const {
  chrome: {header},
  pages: {program},
} = localized;
const {tagline, links} = header;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const programPath = program.path.replace(/\/$/, '') || '/';
const programActive = currentPath === programPath;
const programHref = toHref(program.path);
---

<header
  class="sticky top-0 z-50 border-b border-surface-soft/80 bg-surface-muted/90 backdrop-blur-md"
>
  <div
    class="container-page flex items-center justify-between gap-6 pb-4 pt-[calc(1rem+env(safe-area-inset-top))] sm:gap-8"
  >
    <a href={homeHref} class="flex min-w-0 items-center gap-3 no-underline">
      <img
        src={logoSquareSimpleSmall.src}
        width={logoSquareSimpleSmall.width}
        height={logoSquareSimpleSmall.height}
        alt=""
        class="h-10 w-10 shrink-0 select-none sm:h-12 sm:w-12"
        aria-hidden="true"
      />
      <div class="min-w-0">
        <div
          class="truncate font-display text-xl leading-tight text-ink sm:text-2xl"
        >
          {brand}
        </div>
        <p
          class="mt-0.5 truncate text-xs font-normal leading-tight text-ink-muted sm:text-sm"
        >
          {tagline}
        </p>
      </div>
    </a>

    <nav class="hidden items-center gap-6 lg:flex">
      <a href={`${homeHref}#accueil`} class="nav-link">{links.home}</a>
      <a href={`${homeHref}#massages`} class="nav-link">{links.massages}</a>
      {
        programActive ? (
          <span aria-current="page" class="text-sm font-medium text-ink">
            {links.program}
          </span>
        ) : (
          <a href={programHref} class="nav-link">
            {links.program}
          </a>
        )
      }
      <a href={`${homeHref}#apropos`} class="nav-link">{links.about}</a>
      {
        reserveActive ? (
          <span aria-current="page" class="text-sm font-medium text-ink">
            {links.reserve}
          </span>
        ) : (
          <a
            href={bookingHref}
            class="nav-link"
            data-analytics-event="reserve_click"
          >
            {links.reserve}
          </a>
        )
      }
      <a href={`${homeHref}#contact`} class="nav-link">{links.contact}</a>
    </nav>
    {
      languageSwitchPaths ? (
        <div class="flex items-center gap-2 text-xs font-medium uppercase tracking-[0.1em] text-ink-subtle">
          <a
            href={toHref(languageSwitchPaths.fr)}
            aria-current={locale === 'fr' ? 'page' : undefined}
            class:list={[
              'no-underline transition',
              locale === 'fr' ? 'text-ink' : 'hover:text-ink',
            ]}
          >
            FR
          </a>
          <span>/</span>
          <a
            href={toHref(languageSwitchPaths.en)}
            aria-current={locale === 'en' ? 'page' : undefined}
            class:list={[
              'no-underline transition',
              locale === 'en' ? 'text-ink' : 'hover:text-ink',
            ]}
          >
            EN
          </a>
        </div>
      ) : null
    }
  </div>
  <nav
    class="container-page flex items-center gap-2 overflow-x-auto border-t border-surface-soft/70 pb-3 pt-2 lg:hidden"
    aria-label="Navigation principale"
  >
    <a
      href={`${homeHref}#massages`}
      class="shrink-0 rounded-full px-3 py-1.5 text-sm font-medium text-ink-muted no-underline transition hover:bg-white/70 hover:text-ink"
    >
      {links.massages}
    </a>
    {
      programActive ? (
        <span
          aria-current="page"
          class="shrink-0 rounded-full bg-white px-3 py-1.5 text-sm font-semibold text-ink shadow-card"
        >
          {links.program}
        </span>
      ) : (
        <a
          href={programHref}
          class="shrink-0 rounded-full px-3 py-1.5 text-sm font-medium text-ink-muted no-underline transition hover:bg-white/70 hover:text-ink"
        >
          {links.program}
        </a>
      )
    }
    {
      reserveActive ? (
        <span
          aria-current="page"
          class="shrink-0 rounded-full bg-white px-3 py-1.5 text-sm font-semibold text-ink shadow-card"
        >
          {links.reserve}
        </span>
      ) : (
        <a
          href={bookingHref}
          class="shrink-0 rounded-full bg-brand px-3.5 py-1.5 text-sm font-semibold text-white no-underline shadow-card transition hover:bg-brand-strong"
          data-analytics-event="reserve_click"
        >
          {links.reserve}
        </a>
      )
    }
  </nav>
</header>
