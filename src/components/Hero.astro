---
import {Picture} from 'astro:assets';
import type {HeroData} from '../data/site';
import {getPhoneHref} from '../utils/phone';
import HeroMassageRoom from '../assets/hero-massage-room.png';
import IconImage from './IconImage.astro';

type Props = HeroData & {
  bookingUrl: string;
  phone: string;
  whatsappUrl: string;
};

const {
  subtitle,
  title,
  description,
  imageAlt,
  womenOnlyLabel,
  benefitHighlight,
  bookingUrl,
  phone,
  whatsappUrl,
  primaryCta,
  secondaryCta,
  whatsappCta,
} = Astro.props;
const phoneHref = getPhoneHref(phone);
---

<section id="accueil" class="relative overflow-hidden">
  <div class="absolute inset-0">
    <Picture
      priority
      src={HeroMassageRoom}
      formats={['avif', 'webp']}
      alt={imageAlt}
      class="h-full w-full object-cover"
    />

    <div
      class="absolute inset-0 bg-gradient-to-r from-ink/55 via-ink/25 to-transparent"
    >
    </div>
  </div>

  <div
    class="container-page relative pb-26 pt-24 sm:pb-32 sm:pt-30 lg:pb-40 lg:pt-36"
  >
    <div class="max-w-2xl">
      <p class="mb-4 text-sm uppercase tracking-[0.25em] text-white/80">
        {subtitle}
      </p>
      <div class="mb-6">
        <span
          class="inline-flex items-center gap-2.5 rounded-full border border-white/18 bg-white/12 px-4 py-2 text-sm text-white/95 backdrop-blur-sm"
        >
          <IconImage
            inline
            name="i-lucide-flower"
            class="text-white/90"
            iconClass="h-4 w-4"
          />
          {womenOnlyLabel}
        </span>
      </div>
      <h1
        class="font-display text-5xl leading-tight text-white sm:text-6xl lg:text-7xl"
      >
        {title}
      </h1>
      <p
        class="mt-6 max-w-[28rem] text-pretty text-lg leading-8 text-white/90 sm:max-w-[30rem] sm:text-xl lg:max-w-[26ch]"
      >
        {description}
      </p>

      <p
        class="mt-7 inline-flex max-w-xl items-center gap-2.5 rounded-full bg-white/14 px-4 py-2 text-sm font-medium text-white shadow-soft backdrop-blur-sm"
      >
        <IconImage
          inline
          name="i-lucide-sparkles"
          class="text-white/90"
          iconClass="h-4 w-4"
        />
        <span>{benefitHighlight}</span>
      </p>

      <div class="mt-9 w-fit">
        <div
          class="flex w-full flex-col gap-3.5 sm:w-auto sm:flex-row sm:flex-wrap sm:gap-4"
        >
          <a
            href={bookingUrl}
            class="btn-primary min-h-[3rem] px-6 py-3.5 sm:min-h-0 sm:py-3"
          >
            {primaryCta}
          </a>
          <a
            href={whatsappUrl}
            class="inline-flex min-h-[3rem] items-center justify-center gap-2.5 rounded-full border border-white/28 bg-white/8 px-6 py-3.5 text-sm font-medium text-white/88 shadow-soft backdrop-blur-sm transition hover:border-white/40 hover:bg-white/14 hover:text-white sm:min-h-0 sm:py-3"
            target="_blank"
            rel="noreferrer"
          >
            <IconImage
              inline
              name="i-lucide-message-circle"
              class="text-white/84"
              iconClass="h-4 w-4"
            />
            {whatsappCta}
          </a>
          <a
            href={`tel:${phoneHref}`}
            class="inline-flex min-h-[3rem] items-center justify-center gap-2.5 rounded-full border border-white/18 bg-transparent px-6 py-3.5 text-sm font-medium text-white/76 transition hover:border-white/28 hover:bg-white/8 hover:text-white/92 sm:min-h-0 sm:py-3"
          >
            <IconImage
              inline
              name="i-lucide-phone"
              class="text-white/78"
              iconClass="h-4 w-4"
            />
            {secondaryCta}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
