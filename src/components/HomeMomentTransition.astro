---
import {Picture} from 'astro:assets';
import type {HomeTransitionData} from '../data/site';

type Props = HomeTransitionData;

const {title, heading, text, image} = Astro.props;
---

<section class="bg-surface px-0 py-12 sm:py-14 lg:py-16">
  <div class="container-page">
    <div
      class="grid items-center gap-7 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1fr)] lg:gap-12"
    >
      <div class="max-w-xl">
        <p
          class="text-sm font-medium uppercase tracking-[0.22em] text-brand-strong/82"
        >
          {title}
        </p>
        <p
          class="mt-4 font-display text-3xl leading-tight text-ink sm:text-4xl"
        >
          {heading}
        </p>
        <p class="body-base mt-4 max-w-md">{text}</p>
      </div>

      <div
        class="overflow-hidden rounded-[2rem] shadow-soft ring-1 ring-surface-soft"
      >
        <Picture
          src={image.src}
          formats={['avif', 'webp']}
          fallbackFormat="webp"
          widths={[360, 520, 704, 960, 1200]}
          width={960}
          height={640}
          sizes="(min-width: 1024px) 38rem, (min-width: 640px) calc(100vw - 3rem), calc(100vw - 2rem)"
          alt={image.alt}
          class="h-[18rem] w-full object-cover object-center sm:h-[24rem] lg:h-[28rem]"
          loading="eager"
          decoding="async"
          fetchpriority="low"
        />
      </div>
    </div>
  </div>
</section>
