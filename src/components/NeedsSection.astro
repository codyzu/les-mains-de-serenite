---
import type {SiteData} from '../data/site';
import SectionIntro from './SectionIntro.astro';

type Props = SiteData['needsSection'];

const {title, items} = Astro.props;
---

<section id="besoins" class="section-pad bg-surface-muted">
  <div class="container-page">
    <SectionIntro
      title={title}
      text="Des besoins fréquents pour lesquels ces massages sont particulièrement adaptés."
    />

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {
        items.map((item, index) => (
          <article
            class:list={[
              'card-soft flex items-center gap-4 p-5 shadow-soft sm:p-6',
              index % 2 === 0 ? 'bg-white/82' : 'bg-surface/82',
            ]}
          >
            <div
              class:list={[
                'flex h-11 w-11 shrink-0 items-center justify-center rounded-full shadow-card',
                index % 2 === 0
                  ? 'bg-brand-soft text-brand-strong'
                  : 'bg-accent-soft text-accent-strong',
              ]}
            >
              <span class="i-lucide-sparkles h-5 w-5" />
            </div>
            <p class="text-base font-medium leading-6 text-ink">{item}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
