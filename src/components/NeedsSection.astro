---
import type {NeedsSectionData} from '../data/site';
import SectionIntro from './SectionIntro.astro';

type Props = NeedsSectionData;

const {title, intro, ctaText, items} = Astro.props;
---

<section id="besoins" class="section-pad bg-surface-muted">
  <div class="container-page">
    <SectionIntro title={title} text={intro} />

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {
        items.map((item) => (
          <a
            href={item.href}
            class="card-soft group flex items-start gap-4 bg-white/82 p-5 no-underline shadow-soft transition hover:-translate-y-0.5 hover:bg-white hover:shadow-card sm:p-6"
          >
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-brand-soft text-brand-strong shadow-card">
              <span class="i-lucide-sparkles h-5 w-5" />
            </div>
            <div>
              <h3 class="text-base font-semibold leading-6 text-ink">
                {item.title}
              </h3>
              <p class="mt-2 text-sm leading-6 text-ink-muted">
                {item.description}
              </p>
              <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-brand-strong">
                {item.ctaText ?? ctaText}
                <span class="i-lucide-arrow-right h-4 w-4 transition group-hover:translate-x-0.5" />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
