---
import type {ProgramPreviewData} from '../data/site';
import IconImage from './IconImage.astro';
import SectionIntro from './SectionIntro.astro';

type Props = ProgramPreviewData;

const {title, intro, ctaText, ctaLink, items} = Astro.props;
---

<section class="section-pad bg-surface-muted">
  <div class="container-page">
    <SectionIntro title={title} text={intro} />

    <div class="mt-2 grid gap-6 lg:grid-cols-2">
      {
        items.map((item, index) => {
          const ctaIsExternal = item.ctaLink.startsWith('http');

          return (
            <article class="card-soft flex flex-col bg-white/86 p-6 shadow-soft sm:p-7">
              <div class="flex items-start justify-between gap-5">
                <div class="min-w-0">
                  <p class="text-sm font-medium uppercase tracking-[0.18em] text-brand-strong/80">
                    {item.eyebrow}
                  </p>
                  <h3 class="heading-md mt-3 text-[1.7rem]">{item.title}</h3>
                  <p class="mt-3 text-base font-medium leading-7 text-ink/78">
                    {item.subtitle}
                  </p>
                </div>
                <IconImage
                  name={item.icon}
                  class={
                    index % 2 === 0
                      ? 'bg-brand-soft text-brand-strong'
                      : 'bg-accent-soft text-accent'
                  }
                />
              </div>

              <p class="body-base mt-5">{item.description}</p>
              <p class="mt-5 rounded-2xl bg-surface-muted/80 px-4 py-3 text-sm leading-6 text-ink/72">
                {item.note}
              </p>

              <div class="mt-6 border-t border-ink/8 pt-5">
                <div class="flex flex-wrap items-end justify-between gap-3">
                  <div>
                    <p class="text-sm font-medium uppercase tracking-[0.18em] text-brand-strong/80">
                      {item.priceLabel}
                    </p>
                    <p class="mt-2 font-display text-3xl leading-tight text-ink">
                      {item.price}
                    </p>
                    {item.priceDetail ? (
                      <p class="mt-1 text-sm font-medium text-ink/68">
                        {item.priceDetail}
                      </p>
                    ) : null}
                  </div>
                </div>

                <h4 class="mt-6 text-base font-semibold text-ink">
                  {item.includesTitle}
                </h4>
                <ul class="mt-4 space-y-3">
                  {item.includes.map((includedItem) => (
                    <li class="flex gap-3 text-sm leading-6 text-ink/74">
                      <span class="i-lucide-check mt-1 h-4 w-4 shrink-0 text-brand-strong" />
                      <span>{includedItem}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <a
                href={item.ctaLink}
                target={ctaIsExternal ? '_blank' : undefined}
                rel={ctaIsExternal ? 'noreferrer' : undefined}
                class="mt-auto inline-flex min-h-[3.25rem] w-full items-center justify-center rounded-full border border-brand-soft bg-white/72 px-7 py-4 text-base font-medium text-brand-strong transition hover:bg-brand-soft/62"
                data-analytics-event={item.analyticsEvent}
              >
                {item.ctaText}
              </a>
            </article>
          );
        })
      }
    </div>

    {
      ctaText && ctaLink ? (
        <div class="mt-10 flex justify-center">
          <a
            href={ctaLink}
            class="btn-primary min-h-[3.25rem] px-7 py-4 text-base"
          >
            {ctaText}
          </a>
        </div>
      ) : null
    }
  </div>
</section>
