---
import {Picture} from 'astro:assets';
import type {PromoData} from '../data/site';

interface Props {
  promo?: PromoData;
}

const {promo} = Astro.props;
const ctaIsExternal = promo?.ctaLink.startsWith('http') ?? false;
---

{
  promo ? (
    <section class="bg-surface pb-10 pt-10 sm:pb-12 sm:pt-12 lg:pb-14 lg:pt-16">
      <div class="container-page">
        <div
          class:list={[
            'card-soft overflow-hidden rounded-[2rem] bg-gradient-to-br from-brand-soft/70 via-white/88 to-surface-muted shadow-soft',
            promo.image &&
              'lg:grid lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.85fr)] lg:items-center',
          ]}
        >
          <div class="p-7 sm:p-9 lg:p-12">
            <div
              class:list={[
                'flex flex-col gap-6',
                !promo.image &&
                  'lg:flex-row lg:items-end lg:justify-between lg:gap-10',
              ]}
            >
              <div class="max-w-3xl">
                <p class="text-sm uppercase tracking-[0.25em] text-brand-strong/90">
                  {promo.title}
                </p>
                <h2 class="heading-lg mt-4 max-w-[17ch] text-[2.2rem] sm:text-4xl lg:max-w-[20ch]">
                  {promo.headline}
                </h2>
                <p class="body-lg mt-4 max-w-2xl">{promo.description}</p>
              </div>

              <div
                class:list={[
                  'flex items-start',
                  !promo.image && 'lg:shrink-0 lg:self-end',
                ]}
              >
                <a
                  href={promo.ctaLink}
                  target={ctaIsExternal ? '_blank' : undefined}
                  rel={ctaIsExternal ? 'noreferrer' : undefined}
                  class="btn-primary min-h-[3.25rem] w-full px-7 py-4 text-base sm:w-auto sm:min-w-[14rem]"
                  data-analytics-event={promo.analyticsEvent}
                >
                  {promo.ctaText}
                </a>
              </div>
            </div>
          </div>

          {promo.image ? (
            <div class="aspect-[16/10] overflow-hidden sm:aspect-[4/3] lg:my-7 lg:mr-7 lg:rounded-[1.5rem]">
              <Picture
                src={promo.image.src}
                formats={['avif', 'webp']}
                fallbackFormat="webp"
                widths={[320, 480, 704, 960]}
                width={704}
                height={469}
                sizes="(min-width: 1024px) 26rem, (min-width: 640px) calc(100vw - 3rem), calc(100vw - 2rem)"
                alt={promo.image.alt}
                class="h-full w-full object-cover object-[center_58%]"
              />
            </div>
          ) : null}
        </div>
      </div>
    </section>
  ) : null
}
