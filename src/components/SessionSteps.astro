---
import type {SessionStepsData} from '../data/site';
import SectionIntro from './SectionIntro.astro';

type Props = SessionStepsData;

const {title, intro, steps, reassuranceNote} = Astro.props;
---

<section id="seance" class="section-pad bg-surface">
  <div class="container-page">
    <SectionIntro title={title} text={intro} />

    <div class="grid gap-6 lg:grid-cols-3">
      {
        steps.map((step, index) => (
          <article class="card-soft flex h-full flex-col p-6 sm:p-7">
            <div
              class:list={[
                'mb-5 flex h-16 w-16 items-center justify-center rounded-full text-lg font-semibold',
                index === 1
                  ? 'bg-accent-soft text-accent-strong'
                  : 'bg-brand-soft text-brand-strong',
              ]}
            >
              {index + 1}
            </div>

            <h3 class="heading-md text-[1.55rem]">{step.title}</h3>
            <p class="body-base mt-3">{step.description}</p>
          </article>
        ))
      }
    </div>

    {
      reassuranceNote ? (
        <p class="body-base mt-6 text-center text-ink/68">{reassuranceNote}</p>
      ) : null
    }
  </div>
</section>
