---
import type {SoinsSectionData} from '../data/site';
import SectionIntro from './SectionIntro.astro';
import IconImage from './IconImage.astro';

type Props = SoinsSectionData & {
  showItemActions?: boolean;
};

const {
  title,
  intro,
  introLinks,
  recommendedLabel,
  ctaText,
  ctaLink,
  items,
  showItemActions = true,
} = Astro.props;

const getCardGridClasses = (index: number) => {
  const isLastTabletCard = items.length % 2 === 1 && index === items.length - 1;
  const desktopRemainder = items.length % 3;
  const isFirstDesktopLastRow =
    desktopRemainder > 0 && index === items.length - desktopRemainder;

  return [
    'md:col-span-2',
    isLastTabletCard ? 'md:col-start-2 xl:col-start-auto' : '',
    desktopRemainder === 1 && isFirstDesktopLastRow ? 'xl:col-start-3' : '',
    desktopRemainder === 2 && isFirstDesktopLastRow ? 'xl:col-start-2' : '',
  ];
};
---

<section id="soins" class="section-pad bg-surface">
  <div class="container-page">
    <SectionIntro title={title} text={intro} textLinks={introLinks} />

    <div class="grid gap-6 md:grid-cols-4 xl:grid-cols-6">
      {
        items.map((item, index) => (
          <article
            id={item.anchorId}
            class:list={[
              'card-soft flex scroll-mt-30 flex-col p-6 sm:p-7',
              ...getCardGridClasses(index),
            ]}
          >
            <IconImage
              class={
                index % 2 === 0
                  ? 'bg-brand-soft text-brand-strong'
                  : 'bg-accent-soft text-accent'
              }
              name={item.icon}
            />

            <h3 class="heading-md text-[1.6rem]">{item.title}</h3>
            <p class="body-base mt-3">{item.description}</p>
            {item.note ? (
              <p class="mt-4 rounded-2xl bg-brand-soft/55 px-4 py-3 text-sm leading-6 text-ink/76">
                {item.note}
              </p>
            ) : null}

            <div class="mt-7 space-y-2 border-t border-ink/8 pt-4">
              {item.prices.map((option) => (
                <div
                  class:list={[
                    'rounded-2xl px-3 py-2',
                    option.recommended ? 'py-1.5' : '',
                    option.recommended ? 'bg-brand-soft/70' : 'bg-white/45',
                  ]}
                >
                  {option.recommended ? (
                    <div class="grid grid-cols-[minmax(0,1fr)_auto] items-end gap-x-4 gap-y-0.5">
                      <p class="col-span-2 leading-none text-[0.68rem] font-medium uppercase tracking-[0.16em] text-brand-strong/80">
                        {recommendedLabel}
                      </p>
                      <span class="col-start-1 row-start-2 text-sm font-medium text-ink">
                        {option.duration}
                      </span>
                      <span class="col-start-2 row-start-2 whitespace-nowrap text-right text-sm font-bold text-ink">
                        {option.price}
                      </span>
                    </div>
                  ) : (
                    <div class="flex items-center justify-between gap-4">
                      <span class="text-sm text-ink/68">{option.duration}</span>
                      <span class="whitespace-nowrap text-right text-sm font-medium text-ink">
                        {option.price}
                      </span>
                    </div>
                  )}
                </div>
              ))}
            </div>

            {showItemActions && item.ctaText && item.ctaLink ? (
              <a
                href={item.ctaLink}
                class="mt-6 inline-flex min-h-[2.75rem] w-full items-center justify-center rounded-full border border-brand-soft bg-white/60 px-5 py-3 text-sm font-medium text-brand-strong transition hover:bg-brand-soft/60"
              >
                {item.ctaText}
              </a>
            ) : null}
          </article>
        ))
      }
    </div>

    {
      ctaText && ctaLink ? (
        <div class="mt-10 flex justify-center">
          <a
            href={ctaLink}
            class="btn-primary min-h-[3.25rem] px-7 py-4 text-base"
          >
            {ctaText}
          </a>
        </div>
      ) : null
    }
  </div>
</section>
