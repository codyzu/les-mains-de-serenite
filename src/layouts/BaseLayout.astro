---
import GoogleTag from '../components/GoogleTag.astro';
import {localizedPagePaths} from '../data/site';
import {getBaseUrl} from '../utils/url';

interface Props {
  title: string;
  description?: string;
  openGraphTitle?: string;
  openGraphDescription?: string;
  lang?: string;
  canonicalUrl?: string;
  alternates?: Array<{
    hreflang: string;
    href: string;
  }>;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = '',
  openGraphTitle,
  openGraphDescription,
  lang = 'fr',
  canonicalUrl,
  alternates = [],
  structuredData,
} = Astro.props;
const baseUrl = getBaseUrl();
const publicGaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const gaMeasurementId =
  typeof publicGaMeasurementId === 'string' ? publicGaMeasurementId.trim() : '';
const structuredDataItems = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const transitionPathGroups = [
  localizedPagePaths.home,
  localizedPagePaths.maderotherapie,
  localizedPagePaths.program,
].map((paths) =>
  Object.fromEntries(
    Object.entries(paths).map(([locale, path]) => [
      locale,
      `${baseUrl}${path.replace(/^\//, '')}`,
    ])
  )
);
---

<!doctype html>
<html
  lang={lang}
  data-transition-path-groups={JSON.stringify(transitionPathGroups)}
>
  <head>
    <meta charset="utf8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#F6F3EE" />
    <meta
      name="theme-color"
      content="#F6F3EE"
      media="(prefers-color-scheme: dark)"
    />
    <link
      rel="icon"
      type="image/png"
      href={`${baseUrl}favicon-96x96.png`}
      sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="shortcut icon" href={`${baseUrl}favicon.ico`} />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={`${baseUrl}apple-touch-icon.png`}
    />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href={`${baseUrl}site.webmanifest`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={openGraphTitle ?? title} />
    <meta
      property="og:description"
      content={openGraphDescription ?? description}
    />
    {canonicalUrl ? <meta property="og:url" content={canonicalUrl} /> : null}
    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}
    {
      alternates.map((alternate) => (
        <link
          rel="alternate"
          hreflang={alternate.hreflang}
          href={alternate.href}
        />
      ))
    }
    {
      structuredDataItems.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
    <slot name="head" />
    {gaMeasurementId ? <GoogleTag gaMeasurementId={gaMeasurementId} /> : null}
  </head>
  <body>
    <slot />

    <!-- Cloudflare Web Analytics -->
    {
      import.meta.env.PROD ? (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon='{"token": "cac9cbcf27cb4fd1b8c1f96bc6e63852"}'
        />
      ) : null
    }
    <!-- End Cloudflare Web Analytics -->

    <script is:inline>
      const root = document.documentElement;
      const pathGroups = JSON.parse(root.dataset.transitionPathGroups ?? '[]');
      const normalizedPathGroups = pathGroups.map((group) =>
        Object.values(group).map(
          (path) => new URL(path, location.href).pathname
        )
      );
      const transitionPaths = new Set(normalizedPathGroups.flat());
      const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)');
      const transitionStorageKey = 'page-transition-mode';
      let pendingMode;
      let suppressTransition = false;

      const getMode = (fromValue, toValue) => {
        const from = new URL(fromValue, location.href);
        const to = new URL(toValue, location.href);

        if (
          from.origin !== to.origin ||
          (from.pathname === to.pathname && from.search === to.search)
        ) {
          return undefined;
        }

        const languageChange = normalizedPathGroups.some(
          (group) =>
            group.includes(from.pathname) && group.includes(to.pathname)
        );

        if (languageChange) {
          return 'language';
        }

        return transitionPaths.has(from.pathname) &&
          transitionPaths.has(to.pathname)
          ? 'page'
          : undefined;
      };

      document.addEventListener('click', (event) => {
        const link =
          event.target instanceof Element
            ? event.target.closest('a[href]')
            : null;
        pendingMode =
          link instanceof HTMLAnchorElement
            ? getMode(location.href, link.href)
            : undefined;
      });
      // Form submissions always retain the browser's native navigation.
      document.addEventListener(
        'submit',
        () => {
          suppressTransition = true;
        },
        {capture: true}
      );

      const configureTransition = (event, incoming = false) => {
        if (!event.viewTransition) {
          return;
        }

        const activation = event.activation ?? window.navigation?.activation;
        const from = activation?.from?.url;
        const to = activation?.entry?.url ?? location.href;
        const mode = suppressTransition
          ? undefined
          : (pendingMode ??
            (from ? getMode(from, to) : undefined) ??
            (incoming
              ? sessionStorage.getItem(transitionStorageKey)
              : undefined));

        if (incoming) {
          sessionStorage.removeItem(transitionStorageKey);
        } else if (mode) {
          sessionStorage.setItem(transitionStorageKey, mode);
        } else {
          sessionStorage.removeItem(transitionStorageKey);
        }

        if (reducedMotion.matches || !mode) {
          event.viewTransition.skipTransition();
          return;
        }

        event.viewTransition.types.add(mode);
      };

      addEventListener('pageswap', (event) => {
        configureTransition(event);
      });
      addEventListener('pagereveal', (event) => {
        configureTransition(event, true);
      });
    </script>
  </body>
</html>

<style>
  html,
  body {
    --uno: 'm-0 w-full h-full';
    background-color: #f6f3ee;
  }

  html {
    min-height: 100%;
  }

  body {
    min-height: 100%;
  }
</style>

<style is:global>
  @view-transition {
    navigation: auto;
  }

  html:active-view-transition-type(language)::view-transition-old(root) {
    animation: 220ms cubic-bezier(0.4, 0, 0.2, 1) both language-fade-out;
  }

  html:active-view-transition-type(language)::view-transition-new(root) {
    animation: 220ms cubic-bezier(0.4, 0, 0.2, 1) both language-fade-in;
  }

  html:active-view-transition-type(page)::view-transition-old(root) {
    animation: 240ms cubic-bezier(0.4, 0, 0.2, 1) both page-fade-out;
  }

  html:active-view-transition-type(page)::view-transition-new(root) {
    animation: 240ms cubic-bezier(0.22, 1, 0.36, 1) both page-fade-in;
  }

  @keyframes language-fade-out {
    to {
      opacity: 0;
    }
  }

  @keyframes language-fade-in {
    from {
      opacity: 0;
    }
  }

  @keyframes page-fade-out {
    to {
      opacity: 0;
    }
  }

  @keyframes page-fade-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    @view-transition {
      navigation: none;
    }

    ::view-transition-group(root),
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none;
    }
  }
</style>
