---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import {defaultLocale, getLocalizedSite, type Locale} from '../data/site';
import BaseLayout from './BaseLayout.astro';

interface Props {
  locale?: Locale;
  title: string;
  description?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  reserveLink?: string;
  reserveActive?: boolean;
}

const {
  locale = defaultLocale,
  title,
  description = '',
  structuredData,
  reserveLink,
  reserveActive = false,
} = Astro.props;
const localized = getLocalizedSite(locale);
const structuredDataItems = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<BaseLayout
  lang={localized.lang}
  title={title}
  description={description}
  structuredData={structuredDataItems}
>
  <Header
    locale={locale}
    reserveLink={reserveLink}
    reserveActive={reserveActive}
  />
  <slot />
  <Footer
    locale={locale}
    reserveLink={reserveLink}
    reserveActive={reserveActive}
  />
</BaseLayout>
