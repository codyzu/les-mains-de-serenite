---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import {site} from '../data/site';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  reserveLink?: string;
  reserveActive?: boolean;
}

const {
  title,
  description = '',
  structuredData,
  reserveLink,
  reserveActive = false,
} = Astro.props;
const structuredDataItems = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<BaseLayout
  title={title}
  description={description}
  structuredData={structuredDataItems}
>
  <Header
    brand={site.brand}
    reserveLink={reserveLink}
    reserveActive={reserveActive}
  />
  <slot />
  <Footer
    brand={site.brand}
    reserveLink={reserveLink}
    reserveActive={reserveActive}
  />
</BaseLayout>
