---
import HeroMassageRoom from '../assets/hero-massage-room.png';
import Hero from '../components/Hero.astro';
import PromoSection from '../components/PromoSection.astro';
import NeedsSection from '../components/NeedsSection.astro';
import Massages from '../components/Massages.astro';
import HomeMomentTransition from '../components/HomeMomentTransition.astro';
import ProgramPreview from '../components/ProgramPreview.astro';
import About from '../components/About.astro';
import SessionSteps from '../components/SessionSteps.astro';
import Testimonials from '../components/Testimonials.astro';
import FeltBenefits from '../components/FeltBenefits.astro';
import Booking from '../components/Booking.astro';
import Contact from '../components/Contact.astro';
import type {Locale, LocalizedSiteData, SiteBusinessData} from '../data/site';
import Layout from '../layouts/Layout.astro';

interface Props {
  locale: Locale;
  business: SiteBusinessData;
  localized: LocalizedSiteData;
}

const {locale, business, localized} = Astro.props;
const {
  pages: {home},
} = localized;
const localePaths = {
  fr: '/',
  en: '/en/',
} as const;
const {
  booking: {bookingPath},
  whatsapp: {generalHref: whatsappUrl},
} = home;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': business.seo.schemaType,
  name: business.name,
  image: new URL(HeroMassageRoom.src, business.siteUrl).toString(),
  telephone: business.phone,
  address: {
    '@type': 'PostalAddress',
    ...business.address,
  },
  areaServed: business.seo.areaServed,
  url: business.siteUrl,
};
---

<Layout
  locale={locale}
  canonicalPath={localePaths[locale]}
  alternatePaths={localePaths}
  languageSwitchPaths={localePaths}
  title={home.meta.title}
  description={home.meta.description}
  structuredData={structuredData}
>
  <main>
    <Hero
      {...home.hero}
      bookingUrl={bookingPath}
      phone={business.phone}
      whatsappUrl={whatsappUrl}
    />

    <PromoSection promo={home.promo} />

    <Massages {...home.massagesSection} />

    <HomeMomentTransition {...home.emotionalTransition} />

    <ProgramPreview {...home.programPreview} />

    <NeedsSection {...home.needsSection} />

    <Testimonials {...home.testimonials} />

    <Booking {...home.booking} bookingUrl={bookingPath} />

    <SessionSteps {...home.sessionSteps} />

    <FeltBenefits {...home.feltBenefits} />

    <About {...home.about} />

    <Contact
      {...home.contact}
      phone={business.phone}
      email={business.email}
      whatsappUrl={whatsappUrl}
    />
  </main>
</Layout>
