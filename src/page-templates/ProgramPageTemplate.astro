---
import {Picture} from 'astro:assets';
import CtaReassurance from '../components/CtaReassurance.astro';
import IconImage from '../components/IconImage.astro';
import Testimonials from '../components/Testimonials.astro';
import Practitioner from '../assets/about-practitioner.png';
import ProgramDrainageHero from '../assets/program-drainage-realistic.png';
import ProgramHabitsGuidance from '../assets/program-habits-guidance-no-text.png';
import {
  localizedPagePaths,
  type Locale,
  type LocalePathMap,
  type LocalizedSiteData,
  type ProgramPageData,
  type SiteBusinessData,
} from '../data/site';
import Layout from '../layouts/Layout.astro';

interface Props {
  locale: Locale;
  business: SiteBusinessData;
  localized: LocalizedSiteData;
  programData?: ProgramPageData;
  languageSwitchPaths?: LocalePathMap;
}

const {
  locale,
  business,
  localized,
  programData,
  languageSwitchPaths: providedLanguageSwitchPaths,
} = Astro.props;
const {
  pages: {program},
} = localized;
const page = programData ?? program;
const languageSwitchPaths =
  providedLanguageSwitchPaths ?? localizedPagePaths.program;
const ctaIsExternal = page.cta.href.startsWith('http');
const secondaryCtaIsExternal =
  page.cta.secondaryHref?.startsWith('http') ?? false;
const structuredDataPrice = page.price.amount.replaceAll(/[^\d,.]/g, '');
const methodImage = page.visuals?.methodImage ?? {
  src: ProgramHabitsGuidance,
  alt: 'Guide d’habitudes alimentaires simples et boisson chaude sur une table',
};
const storyImage = page.visuals?.storyImage ?? {
  src: Practitioner,
  alt: 'Zahara pendant une séance de massage bien-être',
};
const storyImageClass =
  storyImage.className ?? 'h-[420px] w-full object-cover object-center';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: page.hero.title,
  description: page.meta.description,
  provider: {
    '@type': business.seo.schemaType,
    name: business.name,
    telephone: business.phone,
    address: {
      '@type': 'PostalAddress',
      ...business.address,
    },
  },
  areaServed: business.seo.areaServed,
  offers: {
    '@type': 'Offer',
    price: structuredDataPrice,
    priceCurrency: 'EUR',
  },
};
---

<Layout
  locale={locale}
  canonicalPath={page.path}
  alternatePaths={languageSwitchPaths}
  languageSwitchPaths={languageSwitchPaths}
  title={page.meta.title}
  description={page.meta.description}
  structuredData={structuredData}
>
  <main>
    <section class="relative overflow-hidden bg-ink">
      <div class="absolute inset-0">
        <Picture
          priority
          src={ProgramDrainageHero}
          formats={['avif', 'webp']}
          fallbackFormat="webp"
          widths={[640, 960, 1280, 1536]}
          width={1536}
          height={1024}
          sizes="100vw"
          alt=""
          class="h-full w-full object-cover object-center"
        />
        <div
          class="absolute inset-0 bg-gradient-to-r from-ink/84 via-ink/58 to-ink/18"
        >
        </div>
      </div>

      <div
        class="container-page relative pb-22 pt-24 sm:pb-28 sm:pt-30 lg:pb-36 lg:pt-36"
      >
        <div class="max-w-3xl">
          <p class="mb-4 text-sm uppercase tracking-[0.25em] text-white/76">
            {page.hero.eyebrow}
          </p>
          <h1
            class="font-display text-5xl leading-tight text-white sm:text-6xl lg:text-7xl"
          >
            {page.hero.title}
          </h1>
          <p
            class="mt-6 max-w-2xl text-pretty text-lg leading-8 text-white/88 sm:text-xl"
          >
            {page.hero.description}
          </p>
          {
            page.hero.reassurance ? (
              <p class="mt-4 max-w-2xl text-base font-medium leading-7 text-white/78">
                {page.hero.reassurance}
              </p>
            ) : null
          }

          <div
            class="mt-7 inline-flex flex-wrap items-center gap-x-3 gap-y-1 rounded-2xl bg-white/14 px-4 py-3 text-white shadow-soft backdrop-blur-sm"
          >
            <span
              class="text-xs font-medium uppercase tracking-[0.18em] text-white/72"
            >
              {page.price.label}
            </span>
            <span class="font-display text-3xl leading-none">
              {page.price.amount}
            </span>
            {
              page.price.detail ? (
                <span class="text-sm text-white/78">{page.price.detail}</span>
              ) : null
            }
            {
              page.price.usualValueLabel && page.price.usualValue ? (
                <span class="text-sm text-white/70">
                  {page.price.usualValueLabel}
                  {page.price.usualValue}
                </span>
              ) : null
            }
          </div>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <a
              href={page.cta.href}
              target={ctaIsExternal ? '_blank' : undefined}
              rel={ctaIsExternal ? 'noreferrer' : undefined}
              class="btn-primary min-h-[3rem] px-7 py-3.5 sm:min-h-0 sm:py-3"
              data-analytics-event={page.cta.analyticsEvent}
            >
              {page.hero.primaryCta}
            </a>
            <a
              href="#contenu-programme"
              class="inline-flex min-h-[3rem] items-center justify-center rounded-full border border-white/24 bg-white/10 px-7 py-3.5 text-sm font-medium text-white/86 shadow-soft backdrop-blur-sm transition hover:border-white/36 hover:bg-white/16 hover:text-white sm:min-h-0 sm:py-3"
            >
              {page.hero.secondaryCta}
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="section-pad bg-surface">
      <div class="container-page">
        <div class="max-w-3xl">
          <h2 class="heading-lg">{page.intro.title}</h2>
          <p class="body-lg mt-5">{page.intro.body}</p>
        </div>
      </div>
    </section>

    <section id="contenu-programme" class="section-pad bg-surface-muted">
      <div class="container-page">
        <div class="grid gap-8 lg:grid-cols-2">
          <div>
            <h2 class="heading-lg">{page.forWhom.title}</h2>
            <div class="mt-7 grid gap-3">
              {
                page.forWhom.items.map((item) => (
                  <article class="card-soft flex items-center gap-4 bg-white/82 p-5 shadow-card">
                    <span class="i-lucide-check h-5 w-5 shrink-0 text-brand-strong" />
                    <p class="text-base font-medium leading-6 text-ink">
                      {item}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>

          <div>
            <h2 class="heading-lg">{page.includes.title}</h2>
            <div class="mt-7 grid gap-3">
              {
                page.includes.items.map((item) => (
                  <article class="card-soft flex items-center gap-4 bg-white/82 p-5 shadow-card">
                    <span class="i-lucide-sparkles h-5 w-5 shrink-0 text-brand-strong" />
                    <p class="text-base font-medium leading-6 text-ink">
                      {item}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-pad bg-surface">
      <div class="container-page">
        <div class="grid gap-14">
          <div
            class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-center"
          >
            <div>
              <h2 class="heading-lg">{page.method.title}</h2>
              <p class="body-lg mt-5">{page.method.body}</p>
            </div>

            <div
              class="overflow-hidden rounded-[2rem] shadow-soft ring-1 ring-surface-soft"
            >
              <Picture
                src={methodImage.src}
                formats={['avif', 'webp']}
                fallbackFormat="webp"
                widths={[360, 520, 704, 900, 1100]}
                width={704}
                height={396}
                sizes="(min-width: 1024px) 38rem, (min-width: 640px) calc(100vw - 3rem), calc(100vw - 2rem)"
                alt={methodImage.alt}
                class="h-[420px] w-full object-cover object-center"
              />
            </div>
          </div>

          <div
            class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-center"
          >
            <div>
              <h2 class="heading-lg">{page.story.title}</h2>
              <p class="body-lg mt-5">{page.story.body}</p>
            </div>

            <div
              class="overflow-hidden rounded-[2rem] shadow-soft ring-1 ring-surface-soft"
            >
              <Picture
                src={storyImage.src}
                formats={['avif', 'webp']}
                fallbackFormat="webp"
                widths={[360, 520, 704, 900]}
                width={704}
                height={1056}
                sizes="(min-width: 1024px) 38rem, (min-width: 640px) calc(100vw - 3rem), calc(100vw - 2rem)"
                alt={storyImage.alt}
                class={storyImageClass}
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    {page.testimonials ? <Testimonials {...page.testimonials} /> : null}

    {
      page.techniques ? (
        <section class="section-pad bg-surface-muted">
          <div class="container-page">
            <div class="mx-auto max-w-3xl text-center">
              <h2 class="heading-lg">{page.techniques.title}</h2>
              <p class="body-lg mt-5">{page.techniques.intro}</p>
            </div>

            <div class="mt-9 grid gap-5 lg:grid-cols-3">
              {page.techniques.items.map((item) => (
                <article class="card-soft bg-white/84 p-6 shadow-card sm:p-7">
                  <IconImage
                    name={item.icon}
                    class="bg-brand-soft text-brand-strong"
                  />
                  <h3 class="heading-md mt-5 text-[1.55rem]">{item.title}</h3>
                  <p class="body-base mt-4">{item.description}</p>
                </article>
              ))}
            </div>
          </div>
        </section>
      ) : null
    }

    <section class="section-pad bg-surface-muted">
      <div class="container-page">
        <h2 class="heading-lg text-center">{page.faq.title}</h2>
        <div class="mx-auto mt-9 grid max-w-5xl gap-4">
          {
            page.faq.items.map((item) => (
              <article class="card-soft bg-white/84 p-6 shadow-card sm:p-7">
                <h3 class="text-lg font-semibold text-ink">{item.question}</h3>
                <p class="body-base mt-3">{item.answer}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-surface px-0 py-10 sm:py-12">
      <div class="container-page">
        <div
          class="card-soft mx-auto max-w-5xl bg-white/84 p-7 shadow-card sm:p-8 lg:flex lg:items-center lg:justify-between lg:gap-10"
        >
          <div class="max-w-3xl">
            <p class="text-sm uppercase tracking-[0.22em] text-brand-strong/82">
              Madérothérapie
            </p>
            <h2 class="heading-md mt-3">
              {page.maderotherapieCrossLink.title}
            </h2>
            <p class="body-base mt-4">
              {page.maderotherapieCrossLink.description}
            </p>
          </div>
          <a
            href={page.maderotherapieCrossLink.href}
            class="mt-6 inline-flex min-h-[3rem] items-center justify-center rounded-full border border-brand/24 px-6 py-3 text-sm font-semibold text-brand-strong no-underline transition hover:bg-brand-soft lg:mt-0 lg:shrink-0"
          >
            {page.maderotherapieCrossLink.text}
          </a>
        </div>
      </div>
    </section>

    {
      page.relatedLinks ? (
        <section class="bg-surface px-0 py-10 sm:py-12">
          <div class="container-page">
            <div class="mx-auto max-w-5xl">
              <p class="text-center text-sm uppercase tracking-[0.22em] text-brand-strong/82">
                {page.relatedLinks.eyebrow}
              </p>
              <h2 class="heading-md mt-3 text-center">
                {page.relatedLinks.title}
              </h2>
              <p class="body-base mx-auto mt-4 max-w-3xl text-center">
                {page.relatedLinks.description}
              </p>
              <div class="mt-7 flex flex-col justify-center gap-3 sm:flex-row sm:flex-wrap">
                {page.relatedLinks.items.map((item) => (
                  <a
                    href={item.href}
                    class="inline-flex min-h-[3rem] items-center justify-center rounded-full border border-brand/24 bg-white/70 px-6 py-3 text-sm font-semibold text-brand-strong no-underline shadow-card transition hover:bg-brand-soft"
                  >
                    {item.text}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </section>
      ) : null
    }

    <section class="section-pad bg-surface">
      <div class="container-page">
        <div
          class="card-soft mx-auto max-w-4xl p-8 text-center shadow-soft sm:p-10 lg:p-12"
        >
          <IconImage
            name="i-lucide-message-circle"
            class="mx-auto bg-brand-soft text-brand-strong"
          />
          <h2 class="heading-lg">{page.cta.title}</h2>
          <p class="body-lg mx-auto mt-4 max-w-2xl">
            {page.cta.description}
          </p>
          <div class="mt-7 flex flex-col items-center justify-center gap-3">
            <a
              href={page.cta.href}
              target={ctaIsExternal ? '_blank' : undefined}
              rel={ctaIsExternal ? 'noreferrer' : undefined}
              class="btn-primary min-h-[3rem] px-7 py-3.5 sm:min-h-0 sm:py-3"
              data-analytics-event={page.cta.analyticsEvent}
            >
              {page.cta.text}
            </a>
            <CtaReassurance
              reassurance={page.cta.reassurance}
              class="mx-auto max-w-2xl"
            />
            {
              page.cta.secondaryText && page.cta.secondaryHref ? (
                <a
                  href={page.cta.secondaryHref}
                  target={secondaryCtaIsExternal ? '_blank' : undefined}
                  rel={secondaryCtaIsExternal ? 'noreferrer' : undefined}
                  class="inline-flex min-h-[3rem] items-center justify-center rounded-full border border-brand/24 px-7 py-3.5 text-sm font-semibold text-brand-strong no-underline transition hover:bg-brand-soft sm:min-h-0 sm:py-3"
                  data-analytics-event={page.cta.secondaryAnalyticsEvent}
                >
                  {page.cta.secondaryText}
                </a>
              ) : null
            }
          </div>
          {
            page.cta.note ? (
              <p class="mt-4 text-sm font-medium text-ink/58">
                {page.cta.note}
              </p>
            ) : null
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
