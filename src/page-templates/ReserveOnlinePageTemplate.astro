---
import Contact from '../components/Contact.astro';
import CalEmbed from '../components/CalEmbed.astro';
import BookingPracticalInfo from '../components/BookingPracticalInfo.astro';
import IconImage from '../components/IconImage.astro';
import {
  localizedPagePaths,
  type Locale,
  type LocalizedSiteData,
  type SiteBusinessData,
} from '../data/site';
import Layout from '../layouts/Layout.astro';

interface Props {
  locale: Locale;
  business: SiteBusinessData;
  localized: LocalizedSiteData;
}

const {locale, business, localized} = Astro.props;
const {
  pages: {reserveOnline, home},
  bookingPracticalInfo,
} = localized;
const localePaths = localizedPagePaths.reserveOnline;
const whatsappUrl = home.whatsapp.generalHref;
---

<Layout
  reserveActive
  locale={locale}
  canonicalPath={localePaths[locale]}
  alternatePaths={localePaths}
  languageSwitchPaths={localePaths}
  title={reserveOnline.meta.title}
  description={reserveOnline.meta.description}
  reserveLink={reserveOnline.reserveLink}
>
  <main class="bg-surface">
    <section
      class="relative overflow-hidden section-pad !pb-5 !pt-8 sm:!pb-7 sm:!pt-10"
    >
      <div
        class="absolute inset-x-0 top-0 h-[26rem] bg-gradient-to-b from-brand-soft/70 via-surface-muted to-transparent"
      >
      </div>

      <div class="container-page relative">
        <div class="mx-auto max-w-3xl text-center">
          <p
            class="text-xs font-medium uppercase tracking-[0.28em] text-ink-muted/90"
          >
            {reserveOnline.hero.kicker}
          </p>

          <h1
            class="heading-xl mt-3 text-[2.5rem] sm:mt-4 sm:text-5xl lg:text-[3.5rem]"
          >
            {reserveOnline.hero.title}
          </h1>
          <p class="body-base mx-auto mt-3 max-w-2xl text-balance sm:mt-4">
            {reserveOnline.hero.description}
          </p>
        </div>

        <div
          class="mx-auto mt-5 grid max-w-5xl grid-cols-2 overflow-hidden rounded-spa border border-surface-soft bg-white/60 sm:mt-6 lg:grid-cols-4"
        >
          {
            reserveOnline.hero.reassuranceItems.map(({icon, label}, index) => (
              <article
                class:list={[
                  'min-w-0 border-surface-soft px-2 py-3.5 text-center sm:px-4 sm:py-4 lg:border-b-0',
                  index < 2 && 'border-b',
                  index % 2 === 0 && 'border-r',
                  index < 3 && 'lg:border-r',
                  index === 3 && 'lg:border-r-0',
                ]}
              >
                <div class="flex justify-center">
                  <IconImage
                    class="mb-0 h-9 w-9 bg-brand-soft text-brand-strong"
                    name={icon}
                    iconClass="h-4.5 w-4.5"
                  />
                </div>
                <p class="mt-2 text-xs font-semibold leading-5 text-ink sm:text-sm">
                  {label}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      data-booking-selector
      id="booking-selector"
      class="section-pad scroll-mt-28 !pb-7 !pt-5 bg-surface-muted/45 sm:!pb-8 sm:!pt-6"
      tabindex="-1"
    >
      <div class="container-page">
        <div class="mx-auto max-w-4xl text-center">
          <h2 class="heading-md text-[2rem] sm:text-[2.2rem]">
            {reserveOnline.scheduler.title}
          </h2>
          <BookingPracticalInfo {...bookingPracticalInfo} />
        </div>

        <div class="mx-auto mt-3 max-w-5xl sm:mt-4">
          <CalEmbed
            calLink="lesmainsdeserenite"
            instructionTitle={reserveOnline.scheduler.instructionTitle}
            instructionDescription={reserveOnline.scheduler
              .instructionDescription}
            selectedInstructionTitle={reserveOnline.scheduler
              .selectedInstructionTitle}
            selectedInstructionDescription={reserveOnline.scheduler
              .selectedInstructionDescription}
            regionLabel={reserveOnline.scheduler.regionLabel}
            resetLabel={reserveOnline.scheduler.resetLabel}
            resetStatus={reserveOnline.scheduler.resetStatus}
          />
        </div>

        <figure
          class="mx-auto mt-6 max-w-2xl border-t border-surface-soft px-5 pt-4 text-center sm:mt-8"
        >
          <blockquote class="text-base leading-7 text-ink-muted">
            “{reserveOnline.hero.testimonialQuote}”
          </blockquote>
          <figcaption class="mt-1.5 text-sm text-ink-subtle">
            — {reserveOnline.hero.testimonialAuthor}
          </figcaption>
        </figure>
      </div>
    </section>

    <Contact
      compact
      {...reserveOnline.contact}
      phone={business.phone}
      email={business.email}
      whatsappUrl={whatsappUrl}
      whatsappHref={reserveOnline.contact.whatsappHref}
    />
  </main>
</Layout>
