---
import {Picture} from 'astro:assets';
import CtaReassurance from '../components/CtaReassurance.astro';
import IconImage from '../components/IconImage.astro';
import Soins from '../components/Soins.astro';
import Testimonials from '../components/Testimonials.astro';
import TeaLakeImage from '../assets/tea-lake.png';
import {
  localizedPagePaths,
  type Locale,
  type LocalizedSiteData,
  type SiteBusinessData,
} from '../data/site';
import Layout from '../layouts/Layout.astro';

interface Props {
  locale: Locale;
  business: SiteBusinessData;
  localized: LocalizedSiteData;
}

const {locale, business, localized} = Astro.props;
const {
  pages: {soins},
} = localized;
const languageSwitchPaths = localizedPagePaths.soins;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: soins.meta.title,
  description: soins.meta.description,
  itemListElement: soins.section.items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.title,
  })),
  provider: {
    '@type': business.seo.schemaType,
    name: business.name,
    telephone: business.phone,
    address: {
      '@type': 'PostalAddress',
      ...business.address,
    },
  },
  areaServed: business.seo.areaServed,
};
---

<Layout
  locale={locale}
  canonicalPath={soins.path}
  alternatePaths={languageSwitchPaths}
  languageSwitchPaths={languageSwitchPaths}
  title={soins.meta.title}
  description={soins.meta.description}
  structuredData={structuredData}
>
  <main>
    <section class="overflow-hidden bg-surface-muted">
      <div class="container-page py-16 sm:py-20 lg:py-24">
        <div class="max-w-3xl">
          <p
            class="mb-4 text-sm font-medium uppercase tracking-[0.25em] text-brand-strong"
          >
            {soins.hero.eyebrow}
          </p>
          <h1 class="heading-xl">{soins.hero.title}</h1>
          <p class="body-lg mt-6 max-w-2xl">{soins.hero.description}</p>
          <p class="mt-4 max-w-2xl text-base leading-7 text-ink/68">
            {soins.hero.reassurance}
          </p>
          <a
            href={soins.hero.ctaHref}
            class="btn-primary mt-8 min-h-[3rem] px-7 py-3.5 sm:min-h-0 sm:py-3"
            data-analytics-event={soins.hero.analyticsEvent}
          >
            {soins.hero.ctaText}
          </a>
        </div>
      </div>
    </section>

    <section class="section-pad bg-surface">
      <div class="container-page">
        <div
          class="grid items-center gap-8 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] lg:gap-12"
        >
          <article class="max-w-2xl">
            <IconImage
              name="i-lucide-sparkles"
              class="bg-brand-soft text-brand-strong"
            />
            <h2 class="heading-lg">{soins.philosophy.title}</h2>
            <p class="body-lg mt-5">{soins.philosophy.description}</p>
          </article>

          <div
            class="overflow-hidden rounded-[2rem] shadow-soft ring-1 ring-surface-soft"
          >
            <Picture
              src={TeaLakeImage}
              alt={soins.transitionImageAlt}
              formats={['avif', 'webp']}
              widths={[640, 960, 1280, 1536]}
              sizes="(min-width: 1024px) 40rem, calc(100vw - 2rem)"
              loading="lazy"
              decoding="async"
              class="aspect-[4/3] w-full object-cover object-[50%_56%] sm:aspect-[16/9] lg:aspect-[5/4]"
            />
          </div>
        </div>
      </div>
    </section>

    <Soins {...soins.section} />

    <section class="bg-surface px-0 pb-12 sm:pb-14">
      <div class="container-page">
        <div
          class="card-soft mx-auto max-w-4xl bg-white/86 p-7 text-center shadow-card sm:p-8"
        >
          <IconImage
            name="i-lucide-message-circle"
            class="mx-auto bg-accent-soft text-accent-strong"
          />
          <h2 class="heading-md">{soins.choiceHelp.title}</h2>
          <p class="body-base mx-auto mt-4 max-w-2xl">
            {soins.choiceHelp.description}
          </p>
          <a
            href={soins.choiceHelp.href}
            class="mt-6 inline-flex min-h-[3rem] items-center justify-center rounded-full border border-brand/24 px-6 py-3 text-sm font-semibold text-brand-strong no-underline transition hover:bg-brand-soft"
            data-analytics-event={soins.choiceHelp.analyticsEvent}
          >
            {soins.choiceHelp.text}
          </a>
          <CtaReassurance
            reassurance={soins.choiceHelp.reassurance}
            class="mx-auto mt-4 max-w-2xl"
          />
        </div>
      </div>
    </section>

    <Testimonials {...soins.testimonials} />

    <section class="bg-surface px-0 py-10 sm:py-12">
      <div class="container-page">
        <div
          class="card-soft mx-auto max-w-5xl bg-white/84 p-7 shadow-card sm:p-8 lg:flex lg:items-center lg:justify-between lg:gap-10"
        >
          <div class="max-w-3xl">
            <p class="text-sm uppercase tracking-[0.22em] text-brand-strong/82">
              {locale === 'en' ? 'Programs' : 'Programmes'}
            </p>
            <h2 class="heading-md mt-3">{soins.programCrossLink.title}</h2>
            <p class="body-base mt-4">
              {soins.programCrossLink.description}
            </p>
          </div>
          <a
            href={soins.programCrossLink.href}
            class="mt-6 inline-flex min-h-[3rem] items-center justify-center rounded-full border border-brand/24 px-6 py-3 text-sm font-semibold text-brand-strong no-underline transition hover:bg-brand-soft lg:mt-0 lg:shrink-0"
          >
            {soins.programCrossLink.text}
          </a>
        </div>
      </div>
    </section>

    <section id="reservation" class="section-pad bg-surface">
      <div class="container-page">
        <div
          class="card-soft mx-auto max-w-4xl p-8 text-center shadow-soft sm:p-10 lg:p-12"
        >
          <IconImage
            name="i-lucide-calendar-heart"
            class="mx-auto bg-brand-soft text-brand-strong"
          />
          <h2 class="heading-lg">{soins.booking.title}</h2>
          <p class="body-lg mx-auto mt-4 max-w-2xl">
            {soins.booking.description}
          </p>
          <a
            href={soins.booking.href}
            class="btn-primary mt-7 min-h-[3rem] px-7 py-3.5 sm:min-h-0 sm:py-3"
            data-analytics-event={soins.booking.analyticsEvent}
          >
            {soins.booking.text}
          </a>
          <CtaReassurance
            reassurance={soins.booking.reassurance}
            class="mx-auto mt-4 max-w-2xl"
          />
        </div>
      </div>
    </section>
  </main>
</Layout>
