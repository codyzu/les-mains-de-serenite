---
import Layout from '../layouts/Layout.astro';
import {site} from '../data/site';
import Contact from '../components/Contact.astro';
import IconImage from '../components/IconImage.astro';

const whatsappUrl =
  'https://wa.me/33618758128?text=Bonjour%2C%20j%27ai%20une%20question%20avant%20de%20r%C3%A9server%20un%20massage.';

const reassuranceItems = [
  {
    icon: 'i-lucide-flower',
    label: 'Réservé aux femmes',
  },
  {
    icon: 'i-lucide-home',
    label: 'Cadre calme et privé',
  },
  {
    icon: 'i-lucide-briefcase-medical',
    label: 'Table et matériel inclus',
  },
  {
    icon: 'i-lucide-wallet',
    label: 'Paiement sur place',
  },
];
---

<Layout
  reserveActive
  title="Réserver un massage à Annecy | Les Mains de Sérénité"
  description="Réservez votre massage bien-être à Annecy. Service réservé aux femmes, réservation simple en ligne, paiement sur place."
  reserveLink="/reserver-en-ligne"
>
  <main class="bg-surface">
    <section
      class="relative overflow-hidden section-pad !pb-10 !pt-14 sm:!pt-18"
    >
      <div
        class="absolute inset-x-0 top-0 h-[26rem] bg-gradient-to-b from-brand-soft/70 via-surface-muted to-transparent"
      >
      </div>

      <div class="container-page relative">
        <div class="mx-auto max-w-4xl text-center">
          <p
            class="text-xs font-medium uppercase tracking-[0.28em] text-ink-muted/90"
          >
            Massage bien-être à Annecy
          </p>

          <h1
            class="heading-xl mt-4 text-[2.6rem] sm:mt-5 sm:text-5xl lg:text-6xl"
          >
            Réserver votre massage bien-être
          </h1>
          <p class="body-lg mx-auto mt-5 max-w-3xl text-balance">
            Choisissez votre massage et votre créneau en toute simplicité. Les
            séances sont proposées sur rendez-vous, dans un cadre calme,
            bienveillant et apaisant.
          </p>
        </div>

        <div
          class="mx-auto mt-9 grid max-w-5xl gap-4 sm:grid-cols-2 xl:grid-cols-4"
        >
          {
            reassuranceItems.map(({icon, label}) => (
              <article class="card-soft min-w-0 p-5 text-center shadow-soft sm:p-6">
                <div class="flex justify-center">
                  <IconImage
                    class="mb-0 bg-brand-soft text-brand-strong"
                    name={icon}
                    iconClass="h-6 w-6"
                  />
                </div>
                <p class="mt-4 text-sm font-semibold leading-6 text-ink">
                  {label}
                </p>
              </article>
            ))
          }
        </div>

        <figure
          class="mx-auto mt-6 max-w-2xl rounded-spa bg-white/50 px-5 py-4 text-center shadow-[0_8px_20px_rgba(62,62,62,0.05)] backdrop-blur-sm"
        >
          <blockquote class="text-base leading-7 text-ink-muted">
            “Un vrai moment de détente, je recommande vivement.”
          </blockquote>
          <figcaption class="mt-2 text-sm text-ink-subtle">
            — Marie, Annecy
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="section-pad !pt-4 bg-surface-muted/45">
      <div class="container-page">
        <div class="mx-auto max-w-4xl text-center">
          <h2 class="heading-md text-[2rem] sm:text-[2.2rem]">
            Choisissez votre créneau
          </h2>
          <p class="mt-3 text-base leading-7 text-ink">
            Choisissez votre massage puis votre créneau en quelques secondes.
          </p>
          <p class="mx-auto mt-3 max-w-3xl text-sm leading-6 text-ink-muted">
            Chaque séance est adaptée à vos besoins du moment, pour vous offrir
            un véritable moment de détente.
          </p>
          <p class="mt-1 text-sm leading-6 text-ink-muted">
            Aucun paiement en ligne. Règlement sur place.
          </p>
          <p
            class="mt-3 text-xs font-medium uppercase tracking-[0.18em] text-ink-subtle"
          >
            Service réservé aux femmes · Massage bien-être sans visée médicale
          </p>
        </div>

        <div
          class="mx-auto mt-6 max-w-5xl rounded-[2rem] bg-white/45 p-1.5 shadow-[0_10px_24px_rgba(62,62,62,0.05)] sm:p-3"
        >
          <div
            id="my-cal-inline-reserver"
            class="min-h-[760px] w-full overflow-hidden rounded-[1.5rem] bg-white sm:min-h-[860px] lg:min-h-[940px]"
          >
          </div>
        </div>
      </div>
    </section>

    <Contact
      phone={site.phone}
      email={site.email}
      whatsappUrl={site.whatsappUrl}
      title="Une question avant de réserver ?"
      subtitle="Je vous réponds rapidement pour vous aider à choisir le massage le plus adapté."
      whatsappDescription="Réponse rapide pour toute question avant réservation."
      phoneDescription="Pour échanger rapidement avant votre réservation."
      emailDescription="Idéal si vous préférez poser votre question par écrit."
      whatsappLabel="Écrire sur WhatsApp"
      whatsappHref={whatsappUrl}
    />
  </main>

  <script>
    type CalArgs = unknown[];
    type QueuedCalApi = {
      (...args: CalArgs): void;
      q?: CalArgs[];
    };
    type CalApi = QueuedCalApi & {
      ns: Record<string, QueuedCalApi>;
      loaded?: boolean;
    };
    type CalWindow = Window & {
      Cal?: CalApi;
    };

    const calScriptUrl = 'https://app.cal.eu/embed/embed.js';
    const calOrigin = 'https://app.cal.eu';
    const calNamespace = 'reserver-en-ligne';
    const calSelector = '#my-cal-inline-reserver';
    const calWindow = window as CalWindow;

    const queueCall = (target: QueuedCalApi, args: CalArgs) => {
      target.q = target.q || [];
      target.q.push(args);
    };

    const ensureCal = (): CalApi => {
      if (calWindow.Cal) {
        return calWindow.Cal;
      }

      const cal = ((...args: CalArgs) => {
        if (args[0] === 'init') {
          const namespace = args[1];

          if (typeof namespace === 'string') {
            const namespaceApi: QueuedCalApi = (...namespaceArgs: CalArgs) => {
              queueCall(namespaceApi, namespaceArgs);
            };

            cal.ns[namespace] = cal.ns[namespace] || namespaceApi;
            queueCall(cal.ns[namespace], args);
            queueCall(cal, ['initNamespace', namespace]);
            return;
          }
        }

        queueCall(cal, args);
      }) as CalApi;

      cal.ns = {};
      cal.loaded = true;

      const script = document.createElement('script');
      script.src = calScriptUrl;
      script.async = true;
      document.head.append(script);

      calWindow.Cal = cal;
      return cal;
    };

    const cal = ensureCal();

    cal('init', calNamespace, {origin: calOrigin});

    cal.ns[calNamespace]('inline', {
      elementOrSelector: calSelector,
      config: {
        layout: 'month_view',
        useSlotsViewOnSmallScreen: true,
      },
      calLink: 'lesmainsdeserenite',
    });

    cal.ns[calNamespace]('ui', {
      hideEventTypeDetails: false,
      layout: 'month_view',
      styles: {
        branding: {
          brandColor: '#6b8f71',
        },
      },
    });
  </script>
</Layout>
